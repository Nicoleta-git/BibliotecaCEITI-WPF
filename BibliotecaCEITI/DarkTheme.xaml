<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="WindowBackground" Color="#0F172A"/>
    <SolidColorBrush x:Key="CardBackground" Color="#1E293B"/>
    <SolidColorBrush x:Key="ControlBackground" Color="#1E293B"/>
    <SolidColorBrush x:Key="InputBackground" Color="#334155"/>
    <SolidColorBrush x:Key="HeaderWhite" Color="#1E293B"/>

    <SolidColorBrush x:Key="BorderBrushLight" Color="#334155"/>
    <SolidColorBrush x:Key="BorderBrushDark" Color="#475569"/>

    <SolidColorBrush x:Key="TextPrimary" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#E2E8F0"/>
    <SolidColorBrush x:Key="TextMuted" Color="#94A3B8"/>
    <SolidColorBrush x:Key="TextGray" Color="#64748B"/>
    <SolidColorBrush x:Key="LabelGray" Color="#94A3B8"/>

    <SolidColorBrush x:Key="PrimaryEmerald" Color="#3B82F6"/>
    <SolidColorBrush x:Key="PrimaryEmeraldHover" Color="#60A5FA"/>

    <SolidColorBrush x:Key="DataGridHeaderBackground" Color="#3B82F6"/>
    <SolidColorBrush x:Key="DataGridHeaderForeground" Color="White"/>
    <SolidColorBrush x:Key="DataGridHeaderBorder" Color="#2563EB"/>

    <SolidColorBrush x:Key="DataGridRowBackground" Color="#1E293B"/>
    <SolidColorBrush x:Key="DataGridRowAlternatingBackground" Color="#26334D"/>
    <SolidColorBrush x:Key="DataGridRowSelectedBackground" Color="#1E3A8A"/>
    <SolidColorBrush x:Key="DataGridRowSelectedForeground" Color="#E0F2FE"/>

    <SolidColorBrush x:Key="PrimaryPurple" Color="#A855F7"/>
    <SolidColorBrush x:Key="TotalBlue" Color="#3B82F6"/>
    <SolidColorBrush x:Key="TotalBlueBg" Color="#1E3A8A"/>
    <SolidColorBrush x:Key="StockGreen" Color="#4ADE80"/>
    <SolidColorBrush x:Key="StockGreenBg" Color="#064E3B"/>
    <SolidColorBrush x:Key="BorrowedOrange" Color="#FB923C"/>
    <SolidColorBrush x:Key="BorrowedOrangeBg" Color="#7C2D12"/>
    <SolidColorBrush x:Key="ReservedPurple" Color="#A855F7"/>
    <SolidColorBrush x:Key="ReservedPurpleBg" Color="#4C1D95"/>

    <Color x:Key="ShadowColor">#000000</Color>

    <Style x:Key="SidebarBorderStyle" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1E293B" Offset="0"/>
                    <GradientStop Color="#121B2A" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
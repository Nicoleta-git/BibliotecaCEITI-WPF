<UserControl x:Class="BibliotecaCEITI.Borrow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             mc:Ignorable="d" 
             Background="#F4F7FE" FontFamily="Segoe UI"
             d:DesignHeight="850" d:DesignWidth="1000">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
                <ResourceDictionary Source="/DefaultControls.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="30">
        <!-- Main layout structure -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Filters -->
            <RowDefinition Height="*"/>
            <!-- Table -->
            <RowDefinition Height="Auto"/>
            <!-- Details -->
            <RowDefinition Height="Auto"/>
            <!-- Pagination -->
        </Grid.RowDefinitions>

        <!-- HEADER SECTION -->
        <Grid Grid.Row="0" Margin="0,0,0,30">
            <StackPanel HorizontalAlignment="Left">
                <TextBlock Text="Împrumuturi" FontSize="28" FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock Text="Gestionarea manualelor și cărților împrumutate." Foreground="#64748B" Margin="0,5,0,0"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Style="{StaticResource GlobalActionButtonStyle}" Click="Button_Click">
                    <StackPanel Orientation="Horizontal">
                        <fa5:ImageAwesome Icon="Solid_Book" Foreground="White" Width="14" Margin="0,0,10,0"/>
                        <TextBlock Text="Împrumut Nou"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- FILTERS SECTION -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Search box container -->
            <Border Grid.Column="0" Margin="0,0,20,0" BorderBrush="#E2E8F0" BorderThickness="1" Background="White" CornerRadius="8" Padding="10,5">
                <Grid>
                    <fa5:ImageAwesome Icon="Solid_Search" Foreground="#94A3B8" Width="14" HorizontalAlignment="Left"/>
                    <TextBox BorderThickness="0" Margin="25,0,0,0" VerticalContentAlignment="Center" x:Name="txtSearch" Height="30" Background="Transparent"/>
                </Grid>
            </Border>

            <ComboBox Grid.Column="1" Margin="0,0,20,0" Height="42" SelectedIndex="0" VerticalContentAlignment="Center">
                <ComboBoxItem Content="Toate Grupele"/>
            </ComboBox>

            <ComboBox Grid.Column="2" Height="42" SelectedIndex="0" VerticalContentAlignment="Center">
                <ComboBoxItem Content="Toate Stările"/>
            </ComboBox>
        </Grid>

        <!-- 3. DATAGRID SECTION -->
        <DataGrid x:Name="BooksGrid"
            Grid.Row="2"
            Style="{StaticResource ModernDataGridStyle}"
            AutoGenerateColumns="True"
            ColumnWidth="*"
            CanUserAddRows="False"
            Margin="0,20,0,20">
        </DataGrid>

        <!-- 4. SELECTED ITEM DETAILS SECTION -->
        <Border Grid.Row="3" Margin="0,25,0,0" Background="White" CornerRadius="15" BorderBrush="#E2E8F0" BorderThickness="1" Padding="25">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Visual placeholder for book cover -->
                <Border Width="70" Height="90" Background="#F8FAFC" CornerRadius="10" Margin="0,0,25,0"/>

                <!-- Information panel bound to selected grid row -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="DETALII ÎMPRUMUT SELECTAT" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8" />

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="{Binding SelectedItem.TitluCarte, ElementName=dgImprumuturi, FallbackValue='Selectați o înregistrare'}" 
                                   FontSize="22" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="{Binding SelectedItem.Autor, ElementName=dgImprumuturi, StringFormat=' de \{0\}'}" 
                                   FontSize="18" Foreground="#64748B" VerticalAlignment="Bottom" Margin="5,0,0,2"/>
                    </StackPanel>

                    <!-- Student and Due Date info -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                            <fa5:ImageAwesome Icon="Solid_User" Width="12" Foreground="#3B82F6" Margin="0,0,8,0"/>
                            <TextBlock Text="Împrumutat de: " Foreground="#64748B"/>
                            <TextBlock Text="{Binding SelectedItem.NumeElev, ElementName=dgImprumuturi, FallbackValue='N/A'}" FontWeight="SemiBold" Foreground="#1E293B"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <fa5:ImageAwesome Icon="Solid_Calendar" Width="12" Foreground="#64748B" Margin="0,0,8,0"/>
                            <TextBlock Text="Termen: " Foreground="#64748B"/>
                            <TextBlock Text="{Binding SelectedItem.termen_returnare, ElementName=dgImprumuturi, StringFormat=\{0:dd.MM.yyyy\}}" FontWeight="SemiBold" Foreground="#EF4444"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Return Date and Status info -->
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                            <fa5:ImageAwesome Icon="Solid_Clock" Width="12" Foreground="#64748B" Margin="0,0,8,0"/>
                            <TextBlock Text="Data Returnării: " Foreground="#64748B"/>
                            <TextBlock Text="{Binding SelectedItem.data_returnare, ElementName=dgImprumuturi, StringFormat=\{0:dd.MM.yyyy\}, FallbackValue='Nerestituit'}" FontWeight="SemiBold" Foreground="#1E293B"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <fa5:ImageAwesome Icon="Solid_Tag" Width="12" Foreground="#64748B" Margin="0,0,8,0"/>
                            <TextBlock Text="Stare: " Foreground="#64748B"/>
                            <TextBlock Text="{Binding SelectedItem.stare, ElementName=dgImprumuturi}" FontWeight="Black" Foreground="#1E293B"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Return action button -->
                <Button Grid.Column="2" 
                        Style="{StaticResource GlobalActionButtonStyle}" 
                        Background="#FEF2F2" 
                        Width="120" 
                        Height="50"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <fa5:ImageAwesome Icon="Solid_CheckCircle" Width="16" Foreground="#EF4444" Margin="0,0,8,0"/>
                        <TextBlock Text="RETURN" Foreground="#EF4444" FontWeight="Black" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
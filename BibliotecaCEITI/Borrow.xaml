<UserControl x:Class="BibliotecaCEITI.Borrow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             mc:Ignorable="d" 
            Background="{DynamicResource WindowBackground}" FontFamily="Segoe UI"
             d:DesignHeight="850" d:DesignWidth="1000">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
                <ResourceDictionary Source="/DefaultControls.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MinHeight="88.203"/>
            <RowDefinition Height="Auto" MinHeight="49.797"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,30">
            <StackPanel HorizontalAlignment="Left">
                <TextBlock Text="Împrumuturi" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock Text="Gestionarea manualelor și cărților împrumutate." Foreground="{DynamicResource TextPrimary}" Margin="0,5,0,0"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Style="{StaticResource GlobalActionButtonStyle}" Click="Manuale_Click" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <fa5:ImageAwesome Icon="Solid_BookOpen" Foreground="White" Width="14" Margin="0,0,10,0"/>
                        <TextBlock Text="Manuale"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource GlobalActionButtonStyle}" Click="ImprumutNou_Click">
                    <StackPanel Orientation="Horizontal">
                        <fa5:ImageAwesome Icon="Solid_Book" Foreground="White" Width="14" Margin="0,0,10,0"/>
                        <TextBlock Text="Împrumut Nou"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Margin="0,88,0,0" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="0,0,20,0" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1" Background="{DynamicResource CardBackground}" CornerRadius="8" Padding="10,5">
                <Grid>
                    <fa5:ImageAwesome Icon="Solid_Search" Foreground="#94A3B8" Width="14" HorizontalAlignment="Left"/>
                    <TextBox Text="Caută un elev..." Foreground="Gray" BorderThickness="0" Margin="25,0,0,0" VerticalContentAlignment="Center" x:Name="txtSearch" FontSize="14" Background="Transparent" TextChanged="txtSearch_TextChanged" GotFocus="txtSearch_GotFocus" LostFocus="txtSearch_LostFocus"/>
                </Grid>
            </Border>

            <ComboBox x:Name="cbGrupe" Grid.Column="1" Margin="0,0,20,0" Height="45" SelectedIndex="0" VerticalContentAlignment="Center" SelectionChanged="cbGrupe_SelectionChanged">
                <ComboBoxItem Content="Toate Grupele"/>
            </ComboBox>

            <ComboBox x:Name="cbStari" Grid.Column="2" Height="45" SelectedIndex="0" VerticalContentAlignment="Center">
                <ComboBoxItem Content="Toate Stările"/>
            </ComboBox>
        </Grid>

        <DataGrid x:Name="BooksGrid"
                  Grid.Row="2"
                  Style="{StaticResource ModernDataGridStyle}"
                  AutoGenerateColumns="True"
                  ColumnWidth="*"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  Margin="0,33,0,172" AutoGeneratingColumn="BooksGrid_AutoGeneratingColumn" SelectionChanged="BooksGrid_SelectionChanged" Grid.RowSpan="2">
        </DataGrid>

        <Border Grid.Row="3" Margin="0,25,0,0" Background="{DynamicResource CardBackground}" CornerRadius="15" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1" Padding="25">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="imgCoperta" Width="70" Height="90" Background="{DynamicResource WindowBackground}" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1" CornerRadius="10" Margin="0,0,25,0"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="DETALII ÎMPRUMUT SELECTAT" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8" />

                    <StackPanel x:Name="titlu1" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock x:Name="titlu" Text="{Binding SelectedItem.TitluCarte, ElementName=BooksGrid, FallbackValue='Selectați o înregistrare'}" 
                                   FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Text="{Binding SelectedItem.Autor, ElementName=BooksGrid, StringFormat=' de \{0\}'}" 
                                   FontSize="18" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Bottom" Margin="5,0,0,2"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                            <fa5:ImageAwesome Icon="Solid_User" Width="12" Foreground="{DynamicResource PrimaryEmerald}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Împrumutat de: " Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="persoana" Text="{Binding SelectedItem.NumeElev, ElementName=BooksGrid, FallbackValue='N/A'}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <fa5:ImageAwesome Icon="Solid_Calendar" Width="12" Foreground="{DynamicResource TextMuted}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Termen: " Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SelectedItem.termen_returnare, ElementName=BooksGrid, StringFormat=\{0:dd.MM.yyyy\}}" FontWeight="SemiBold" Foreground="#EF4444" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="termen_limita" Text="Nespecificat" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="5,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,0" VerticalAlignment="Center">
                            <fa5:ImageAwesome Icon="Solid_Clock" Width="12" Foreground="{DynamicResource TextMuted}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Data Returnării: " Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="returnare" Text="{Binding SelectedItem.data_returnare, ElementName=BooksGrid, StringFormat=\{0:dd.MM.yyyy\}, FallbackValue='Nerestituit'}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <fa5:ImageAwesome Icon="Solid_Tag" Width="12" Foreground="{DynamicResource TextMuted}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Stare: " Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SelectedItem.stare, ElementName=BooksGrid}" FontWeight="Black" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="stare_imprumut" Text="Nespecificat" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="5,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <Button x:Name="returneaza" Grid.Column="2" 
                        Style="{StaticResource GlobalActionButtonStyle}" 
                        Background="#22EF4444" 
                        Width="120" 
                        Height="50"
                        VerticalAlignment="Center" Click="Button_Click">
                    <StackPanel Orientation="Horizontal">
                        <fa5:ImageAwesome Icon="Solid_CheckCircle" Width="16" Foreground="#EF4444" Margin="0,0,8,0"/>
                        <TextBlock Text="RETURN" Foreground="#EF4444" FontWeight="Black" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
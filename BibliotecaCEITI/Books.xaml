<UserControl x:Class="BibliotecaCEITI.Books"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             mc:Ignorable="d"
             Background="{DynamicResource WindowBackground}" FontFamily="Segoe UI" 
             d:DesignHeight="600" d:DesignWidth="900">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="SearchBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushLight}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Height" Value="45"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,25" Grid.ColumnSpan="2">
            <TextBlock x:Name="txtBook" Text="Gestiune Inventar (Cărți)" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,10,0,20" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource SearchBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="45"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <fa5:ImageAwesome Icon="Solid_Search" Foreground="{DynamicResource TextMuted}" Width="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBox x:Name="SearchTextBox" Grid.Column="1" VerticalContentAlignment="Center" BorderThickness="0" Background="Transparent" 
                             Foreground="{DynamicResource TextPrimary}" CaretBrush="{DynamicResource TextPrimary}"
                             Tag="Caută după Titlu, Autor sau ISBN..." Padding="5,0" FontSize="14" Margin="0,2,3,3" GotFocus="SearchTextBox_GotFocus" LostFocus="SearchTextBox_LostFocus" TextChanged="SearchTextBox_TextChanged"/>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="15,0,0,0">

                <Button x:Name="BtnSwitchArhiva" Style="{StaticResource ActionButtonStyle}" ToolTip="Afișează cărțile arhivate" Margin="0,0,10,0" Click="BtnSwitchArhiva_Click">
                    <StackPanel Orientation="Horizontal">
                        <fa5:ImageAwesome x:Name="iconArhiva" Icon="Solid_Archive" Foreground="{DynamicResource TextPrimary}" Width="14" Margin="0,0,8,0"/>
                        <TextBlock x:Name="TextArhiva" Text="Vezi Arhiva" Foreground="{DynamicResource TextPrimary}"/>
                    </StackPanel>
                </Button>

                <Button x:Name="RefreshBooks" Style="{StaticResource ActionButtonStyle}" ToolTip="Actualizează inventarul" Margin="0,0,10,0" Click="RefreshBooks_Click">
                    <fa5:ImageAwesome Icon="Solid_SyncAlt" Foreground="{DynamicResource TextPrimary}" Width="14"/>
                </Button>

                <Button x:Name="AddBook" Style="{StaticResource GlobalActionButtonStyle}" Foreground="White" Click="AddBook_Click" Visibility="Visible">
                    <StackPanel Orientation="Horizontal">
                        <fa5:ImageAwesome Icon="Solid_Plus" Foreground="White" Width="12" Margin="0,0,10,0"/>
                        <TextBlock x:Name="txtAdd" Text="Adauga carte"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <DataGrid x:Name="BooksGrid"
                  Grid.Row="2"
                  Grid.ColumnSpan="2"
                  IsReadOnly="True"
                  Style="{DynamicResource ModernDataGridStyle}"
                  AutoGenerateColumns="False" 
                  ColumnWidth="*"
                  CanUserAddRows="False"
                  Margin="0,10,0,20" 
                  SelectionChanged="BooksGrid_SelectionChanged" 
                  HorizontalAlignment="Stretch"
                  Width="NaN">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Denumire" 
                                    Binding="{Binding Titlu}" 
                                    Width="3*" />

                <DataGridTextColumn Header="Autor" 
                                    Binding="{Binding Autor}" 
                                    Width="1.8*" />

                <DataGridTextColumn Header="ISBN" 
                                    Binding="{Binding ISBN}" 
                                    Width="1.7*" />

                <DataGridTextColumn Header="Nr. Exemplare" 
                                    Binding="{Binding Total_Exemplare}" 
                                    Width="1*" />

                <DataGridTemplateColumn x:Name="ColActions" Header="Acțiuni" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="+ exemplar" 
                                    Click="BtnAdaugaExemplar_Click" 
                                    CommandParameter="{Binding Id_Carte}"
                                    Foreground="White" 
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{DynamicResource PrimaryEmerald}" 
                                                CornerRadius="5" 
                                                Padding="8,4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>

        </DataGrid>

        <DataGrid x:Name="ExemplareGrid"
          Grid.Row="2"
          Grid.ColumnSpan="2"
          IsReadOnly="True"
          Style="{DynamicResource ModernDataGridStyle}"
          AutoGenerateColumns="False" 
          ColumnWidth="*"
          CanUserAddRows="False"
          Margin="0,10,0,20" 
          SelectionChanged="ExemplareGrid_SelectionChanged" 
          HorizontalAlignment="Stretch"
          Width="NaN"
          Visibility="Collapsed">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Cod_Inventar" 
                            Binding="{Binding Cod_Inventar}" 
                            Width="3*" />

                <DataGridTextColumn Header="Stare" 
                            Binding="{Binding Stare}" 
                            Width="1.8*" />

                <DataGridTemplateColumn x:Name="ColArhivareExemplar" Header="Acțiuni" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Arhivează" 
                                    Click="BtnActiuneExemplar_Click" 
                                    CommandParameter="{Binding Cod_Inventar}"
                                    Foreground="White" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{DynamicResource PrimaryEmerald}" CornerRadius="5" Padding="8,4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn x:Name="ColDezarhivareExemplar" Header="Acțiuni" Width="*" Visibility="Collapsed">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Dezarhivează" 
                                    Click="BtnActiuneExemplar_Click" 
                                    CommandParameter="{Binding Cod_Inventar}"
                                    Foreground="White" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{DynamicResource PrimaryBlue}" CornerRadius="5" Padding="8,4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>

        </DataGrid>

        <Border Grid.Row="3" Background="{DynamicResource CardBackground}" CornerRadius="12" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1" Padding="25" Grid.ColumnSpan="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Width="70" Height="95" Background="{DynamicResource WindowBackground}" CornerRadius="8" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1" Margin="0,0,20,0">
                    <Image x:Name="imgCoperta" Stretch="Uniform"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="detalii" Text="DETALII CARTE" FontSize="10" FontWeight="Black" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,5"/>
                    <TextBlock x:Name="titlu_exemplar" Text="{Binding SelectedItem.Titlu, ElementName=BooksGrid, FallbackValue='Selectați o carte'}" 
                               FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>

                    <WrapPanel Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,0"/>
                        <StackPanel x:Name="locatie_exemplar" Orientation="Horizontal" Margin="0,0,20,0" Visibility="Collapsed">
                            <fa5:ImageAwesome Icon="Solid_MapMarkerAlt" Width="12" Foreground="{DynamicResource PrimaryBlue}" Margin="0,0,5,0"/>
                            <TextBlock Text="Locație: " Foreground="{DynamicResource TextMuted}"/>
                            <TextBlock x:Name="locatie" Text="{Binding SelectedItem.LocatieCompleta, FallbackValue='N/A'}" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                            <fa5:ImageAwesome Icon="Solid_Building" Width="12" Foreground="{DynamicResource TextMuted}" Margin="0,0,5,0"/>
                            <TextBlock Text="Editura: " Foreground="{DynamicResource TextMuted}"/>
                            <TextBlock x:Name="editura" Text="{Binding SelectedItem.EdituraDenumire, FallbackValue='Nespecificat'}" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <fa5:ImageAwesome Icon="Solid_Tag" Width="12" Foreground="{DynamicResource TextMuted}" Margin="0,0,5,0"/>
                            <TextBlock Text="Tip: " Foreground="{DynamicResource TextMuted}"/>
                            <TextBlock x:Name="tip" Text="{Binding SelectedItem.CategorieTip, FallbackValue='Carte'}" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="btnEditare" Style="{StaticResource ActionButtonStyle}" Click="EditBtn_Click" Background="#223B82F6" Foreground="{DynamicResource PrimaryBlue}" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <fa5:ImageAwesome Icon="Solid_Edit" Width="14" Margin="0,0,10,0" Foreground="{DynamicResource PrimaryBlue}"/>
                            <TextBlock Text="Editare"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btnArhiveaza" Style="{StaticResource ActionButtonStyle}" Background="#223B82F6" Foreground="{DynamicResource PrimaryBlue}" Margin="0,0,10,0" Click="arhiveaza_Click">
                        <StackPanel Orientation="Horizontal">
                            <fa5:ImageAwesome Icon="Solid_Archive" Width="14" Margin="0,0,10,0" Foreground="{DynamicResource PrimaryBlue}"/>
                            <TextBlock x:Name="txtArhiveaza" Text="Arhivează"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btnDezarhiveaza" Style="{StaticResource ActionButtonStyle}" Background="#223B82F6" Foreground="{DynamicResource PrimaryBlue}" Margin="0,0,10,0" Visibility="Collapsed" Click="dezarhiveaza_Click">
                        <StackPanel Orientation="Horizontal">
                            <fa5:ImageAwesome Icon="Solid_Archive" Width="14" Margin="0,0,10,0" Foreground="{DynamicResource PrimaryBlue}"/>
                            <TextBlock x:Name="txtDezarhiveaza" Text="Dezarhivează"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btnShowExemplare" Style="{StaticResource ActionButtonStyle}" Background="#22F59E0B" Foreground="#F59E0B" Margin="0,0,10,0" Click="btnShowExemplare_Click">
                        <StackPanel Orientation="Horizontal">
                            <fa5:ImageAwesome Icon="Solid_LayerGroup" Width="14" Margin="0,0,10,0" Foreground="#F59E0B"/>
                            <TextBlock Text="Gestionează exemplare"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="StergeBtn" Style="{StaticResource ActionButtonStyle}" Background="#22EF4444" Foreground="#EF4444" Click="StergeBtn_Click">
                        <fa5:ImageAwesome Icon="Solid_TrashAlt" Width="14" Foreground="#EF4444"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
<UserControl x:Class="BibliotecaCEITI.Books"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             mc:Ignorable="d"
             Background="#F5F7FA" FontFamily="Segoe UI" 
             d:DesignHeight="600" d:DesignWidth="900">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- SEARCH BAR STYLE: Visual container for the search input -->
            <Style x:Key="SearchBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="White"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Height" Value="45"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Title Section -->
            <RowDefinition Height="Auto"/>
            <!-- Search & Add Section -->
            <RowDefinition Height="*"/>
            <!-- Data Table Section -->
            <RowDefinition Height="Auto"/>
            <!-- Details Panel Section -->
        </Grid.RowDefinitions>

        <!-- PAGE HEADER -->
        <StackPanel Grid.Row="0" Margin="0,0,0,25">
            <TextBlock Text="Gestiune Inventar (Carti)" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
        </StackPanel>

        <!-- SEARCH AND ADD ACTIONS -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Search Input with Icon -->
            <Border Style="{StaticResource SearchBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="45"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <fa5:ImageAwesome Icon="Solid_Search" Foreground="#A0AEC0" Width="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBox x:Name="SearchTextBox" Grid.Column="1" VerticalContentAlignment="Center" BorderThickness="0" Background="Transparent" 
                             Tag="Caută după Titlu, Autor sau ISBN..." Padding="5,0" FontSize="14" Margin="0,2,3,3" TextChanged="SearchTextBox_TextChanged"/>
                </Grid>
            </Border>

            <!-- Add New Book Button -->
            <Button Grid.Column="1" Margin="15,0,0,0" Style="{StaticResource ActionButtonStyle}" Background="{StaticResource PrimaryBlue}" Foreground="White" Click="AddBook_Click">
                <StackPanel Orientation="Horizontal">
                    <fa5:ImageAwesome Icon="Solid_Plus" Foreground="White" Width="12" Margin="0,0,10,0"/>
                    <TextBlock Text="Adauga carte"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- MAIN DATA GRID-->
        <DataGrid x:Name="BooksGrid"
          Grid.Row="2"
          IsReadOnly="True"
          Style="{StaticResource ModernDataGridStyle}"
          AutoGenerateColumns="True"
          ColumnWidth="*"
          CanUserAddRows="False"
          Margin="0,20,0,20" SelectionChanged="BooksGrid_SelectionChanged" AutoGeneratingColumn="BooksGrid_AutoGeneratingColumn"/>

        <!-- SELECTION DETAILS PANEL: Shows info about the currently selected book -->
        <Border Grid.Row="3" Background="White" CornerRadius="12" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" Padding="25">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Thumbnail -->
                    <ColumnDefinition Width="*"/>
                    <!-- Main Info -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Quick Actions -->
                </Grid.ColumnDefinitions>

                <!-- Book Thumbnail Preview -->
                <Border Width="70" Height="95" Background="#F7FAFC" CornerRadius="8" BorderBrush="#EDF2F7" BorderThickness="1" Margin="0,0,20,0">
                    <Image x:Name="imgCoperta" Stretch="Uniform"/>
                </Border>

                <!-- Expanded Book Details -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="LOCALIZARE ȘI DETALII EXEMPLAR" FontSize="10" FontWeight="Black" Foreground="#A0AEC0" Margin="0,0,0,5"/>
                    <TextBlock x:Name="titlu_exemplar" Text="{Binding SelectedItem.Titlu, ElementName=BooksGrid, FallbackValue='Selectați un exemplar'}" 
                               FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>

                    <!-- Info Badges (Location, Publisher, Type) -->
                    <WrapPanel Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                            <fa5:ImageAwesome Icon="Solid_MapMarkerAlt" Width="12" Foreground="{StaticResource PrimaryBlue}" Margin="0,0,5,0"/>
                            <TextBlock Text="Locație: " Foreground="{StaticResource TextMuted}"/>
                            <TextBlock x:Name="locatie" Text="{Binding SelectedItem.LocatieCompleta, FallbackValue='N/A'}" Foreground="{StaticResource TextDark}" FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                            <fa5:ImageAwesome Icon="Solid_Building" Width="12" Foreground="{StaticResource TextMuted}" Margin="0,0,5,0"/>
                            <TextBlock Text="Editura: " Foreground="{StaticResource TextMuted}"/>
                            <TextBlock x:Name="editura" Text="{Binding SelectedItem.EdituraDenumire, FallbackValue='Nespecificat'}" Foreground="{StaticResource TextDark}" FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <fa5:ImageAwesome Icon="Solid_Tag" Width="12" Foreground="{StaticResource TextMuted}" Margin="0,0,5,0"/>
                            <TextBlock Text="Tip: " Foreground="{StaticResource TextMuted}"/>
                            <TextBlock x:Name="tip" Text="{Binding SelectedItem.CategorieTip, FallbackValue='Carte'}" Foreground="{StaticResource TextDark}" FontWeight="SemiBold"/>
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>

                <!-- CONTEXTUAL ACTIONS: Edit and Delete buttons for the selected item -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource ActionButtonStyle}" Click="EditBtn_Click" Background="#EDF2F7" Foreground="#2B6CB0" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <fa5:ImageAwesome Icon="Solid_Edit" Width="14" Margin="0,0,10,0" Foreground="#2B6CB0"/>
                            <TextBlock Text="Editare"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ActionButtonStyle}" Background="#FFF5F5" Foreground="#C53030" Click="StergeBtn_Click">
                        <fa5:ImageAwesome Icon="Solid_Archive" Width="14" Foreground="#C53030"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
<UserControl x:Class="BibliotecaCEITI.AddBook"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             mc:Ignorable="d"
             d:Height="780" d:Width="950"
             Background="#F4F7FE"  FontFamily="Segoe UI">

    <UserControl.Resources>
        <!-- STYLE: Navigation Link Button -->
        <Style x:Key="BackButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#3B82F6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#2563EB"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Back Button & Header -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="Auto"/>
            <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <StackPanel Grid.Row="0" Margin="0,0,0,30">
            <Button x:Name="btnBack" Style="{StaticResource BackButtonStyle}" Margin="0,0,0,15" HorizontalAlignment="Left" Click="BackBtn_Click">
                <StackPanel Orientation="Horizontal">
                    <fa5:ImageAwesome Icon="Solid_ArrowLeft" Width="12" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="0,0,8,0"/>
                    <TextBlock Text="Înapoi la listă" FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <TextBlock Text="Adăugare carte nouă" FontSize="24" FontWeight="Bold" Foreground="#1E293B"/>
        </StackPanel>

        <!-- Form Content Area -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Column: Image Selection -->
                <StackPanel Grid.Column="0" Margin="0,0,30,0">
                    <TextBlock Text="Coperta cărții" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Border BorderBrush="#E2E8F0" BorderThickness="1" Background="White" Height="300" CornerRadius="8">
                        <Image x:Name="imgPreview" Width="227" Stretch="Uniform"/>
                    </Border>

                    <Button Content="Alege fișier" Margin="0,15,0,20" Width="229" HorizontalAlignment="Left"
                            Background="#F1F5F9" BorderThickness="0" Padding="10,8" Cursor="Hand"/>

                    <TextBlock Text="URL Copertă" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBox x:Name="txtCopertaUrl" Tag="https://..." Height="35" VerticalContentAlignment="Center" Padding="5"/>
                </StackPanel>

                <!-- Right Column: Book Details -->
                <StackPanel Grid.Column="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,15">
                            <TextBlock Text="Titlu carte *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtTitlu" Height="35" VerticalContentAlignment="Center" Padding="5"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,15">
                            <TextBlock Text="Autor *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <ComboBox x:Name="cbAutor" DisplayMemberPath="Nume" Height="35"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,15">
                            <TextBlock Text="Ediție" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtEditie" Height="35" VerticalContentAlignment="Center" Padding="5"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,15">
                            <TextBlock Text="Categorie *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <ComboBox x:Name="cbCategorie" Height="35"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="10,0,0,15">
                            <TextBlock Text="ISBN" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtIsbn" Height="35" VerticalContentAlignment="Center" Padding="5"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,10,15">
                            <TextBlock Text="Editura *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <ComboBox x:Name="cbEditura" Height="35"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Grid.Column="1" Margin="10,0,0,15">
                            <TextBlock Text="An apariție (YYYY) *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtAnPublicare" Height="35" VerticalContentAlignment="Center" Padding="5"/>
                        </StackPanel>

                        <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,10,15">
                            <TextBlock Text="Preț vânzare (MDL)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtPretMdl" Height="35" VerticalContentAlignment="Center" Padding="5"/>
                        </StackPanel>

                        <StackPanel Grid.Row="4" Grid.Column="1" Margin="10,0,0,15">
                            <TextBlock Text="Preț chirie (Manuale)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtPretChirie" Height="35" VerticalContentAlignment="Center" Padding="5"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Text="Limba *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cbLimba" Width="250" HorizontalAlignment="Left" Margin="0,0,0,15" Height="35"/>

                        <TextBlock Text="Descriere" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtDescriere" Height="100" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="10"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Footer: Action Buttons -->
        <Border Grid.Row="2" Padding="0,20,0,0" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Anulează" Width="100" Margin="0,0,15,0" Height="40" Background="Transparent" BorderBrush="#E2E8F0" BorderThickness="1" Cursor="Hand"/>
                <Button x:Name="btnSalveaza" Content="Salvează cartea" Width="180" Height="40" Background="#3B82F6" Foreground="White" FontWeight="Bold" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
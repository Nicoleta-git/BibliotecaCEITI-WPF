<UserControl x:Class="BibliotecaCEITI.Delete"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             mc:Ignorable="d" 
             Background="{DynamicResource WindowBackground}"
             FontFamily="Segoe UI"
             d:DesignHeight="650" d:DesignWidth="900">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="40,30">

                <Button x:Name="btnBack" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BackBtn_Click" HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <fa5:ImageAwesome Icon="Solid_ArrowLeft" Width="10" Margin="0,0,8,0" Foreground="#4483EC"/>
                        <TextBlock Text="Înapoi la listă" Foreground="#4483EC" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <TextBlock Text="Ștergere carte" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,25"/>

                <Border Background="{DynamicResource CardBackground}" CornerRadius="8" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1" Padding="30" Height="575">
                    <StackPanel>

                        <Border Background="#22EF4444" BorderBrush="#44EF4444" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,25">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <fa5:ImageAwesome Icon="Solid_ExclamationTriangle" Width="14" Foreground="#EF4444" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Foreground="#EF4444" TextWrapping="Wrap" VerticalAlignment="Center">
                                    <Run Text="Atenție!" FontWeight="Bold"/>
                                    <Run Text=" Această acțiune este ireversibilă."/>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <TextBlock Text="Carte" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8"/>
                        <TextBox x:Name="txtNumeCarte" Text="Enigma Otiliei - George Călinescu" IsReadOnly="True" 
                                 Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource TextPrimary}" Padding="10" Margin="0,0,0,20" BorderBrush="{DynamicResource BorderBrushLight}"/>

                        <TextBlock Text="Motiv stergere *" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8"/>
                        <ComboBox x:Name="cbMotiv" 
                                  Style="{StaticResource ModernComboBox}"
                                  Margin="0,0,0,20">
                            <ComboBoxItem Content="Selectează motivul" IsSelected="True" IsEnabled="False"/>
                            <ComboBoxItem Content="Deteriorare fizică"/>
                            <ComboBoxItem Content="Uzura morală"/>
                            <ComboBoxItem Content="Pierdere / Dispariție"/>
                            <ComboBoxItem Content="Transfer către altă unitate"/>
                        </ComboBox>

                        <TextBlock Text="Observații" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8"/>
                        <TextBox x:Name="txtObservatii" Height="80" TextWrapping="Wrap" AcceptsReturn="True" 
                                 Padding="10" Margin="0,0,0,20" BorderBrush="{DynamicResource BorderBrushLight}" Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource TextPrimary}" VerticalContentAlignment="Top" GotFocus="txtObservatii_GotFocus" LostFocus="txtObservatii_LostFocus"/>

                        <Border Background="{DynamicResource WindowBackground}" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,30">
                            <CheckBox x:Name="chkConfirmare" Cursor="Hand">
                                <TextBlock Text="Confirm că am verificat datele și doresc casarea definitivă a acestei cărți." 
                                           TextWrapping="Wrap" Foreground="{DynamicResource TextPrimary}" Margin="8,0,0,0"/>
                            </CheckBox>
                        </Border>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="btnAnuleaza" Content="Anulează" Style="{StaticResource SecondaryButtonStyle}" Width="120" Margin="0,0,15,0"/>

                            <Button x:Name="btnCaseaza" 
                                    Content="Șterge" 
                                    Style="{StaticResource DangerButtonStyle}" 
                                    Width="160"
                                    IsEnabled="{Binding IsChecked, ElementName=chkConfirmare}" Click="btnCaseaza_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
<UserControl x:Class="BibliotecaCEITI.SystemSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             xmlns:local="clr-namespace:BibliotecaCEITI"
             mc:Ignorable="d"
             Background="{DynamicResource WindowBackground}"
             FontFamily="Segoe UI"
             d:Height="1500" d:DesignWidth="1000">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="DefaultControls.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="Transparent" Padding="40,30,40,10">
            <Grid>
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Button x:Name="btnBack" Background="Transparent" BorderThickness="0" Cursor="Hand"
                    Click="BtnInapoi_Click" HorizontalAlignment="Left" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <fa5:ImageAwesome Icon="Solid_ArrowLeft" Width="10" Margin="0,0,8,0" Foreground="{DynamicResource TotalBlue}"/>
                            <TextBlock Text="Înapoi la setări" Foreground="{DynamicResource TotalBlue}" FontSize="15"
                               FontWeight="Medium" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <TextBlock Text="Setări avansate" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="Configurarea bazei de date și a sistemului"
                       Foreground="{DynamicResource TextMuted}" FontSize="13" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="btnSalveazaSistem" Width="180" Height="38"
                    Style="{StaticResource GlobalActionButtonStyle}"
                    Click="BtnSalveazaSistem_Click">
                        <StackPanel Orientation="Horizontal">
                            <fa5:ImageAwesome Icon="Solid_Check" Width="14" Foreground="White" Margin="0,0,8,0"/>
                            <TextBlock Text="Salvează modificările"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="40,0,40,40" Margin="-1,10,1,1" Grid.Row="1">
            <StackPanel>

                <Border Background="{DynamicResource CardBackground}" CornerRadius="12" BorderBrush="{DynamicResource BorderBrushLight}"
        BorderThickness="1" Padding="25" Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,18">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="36" Height="36" CornerRadius="8"
                        Background="{DynamicResource TotalBlueBg}" Margin="0,0,12,0">
                                    <fa5:ImageAwesome Icon="Solid_InfoCircle" Width="16" Foreground="{DynamicResource TotalBlue}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="General" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBlock Text="Informații generale despre bibliotecă și contact."
                               Foreground="{DynamicResource TextMuted}" FontSize="12"/>
                                </StackPanel>
                            </StackPanel>
                            <Button x:Name="btnEditGeneral" HorizontalAlignment="Right"
                    Width="110" Height="34"
                    Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1"
                    Cursor="Hand" Click="BtnEditGeneral_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                                <StackPanel Orientation="Horizontal">
                                    <fa5:ImageAwesome Icon="Solid_Pen" Width="12" Foreground="{DynamicResource TotalBlue}" Margin="0,0,7,0"/>
                                    <TextBlock Text="Editează" Foreground="{DynamicResource TotalBlue}" FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <StackPanel x:Name="pnlGeneralView">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Nume bibliotecă / instituție" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextMuted}" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock x:Name="lblDenumireInstitutie" Grid.Column="1"
                           Foreground="{DynamicResource TextPrimary}" FontSize="13" VerticalAlignment="Center"/>
                            </Grid>
                            <Separator Background="{DynamicResource BorderBrushLight}" Margin="0,4,0,10"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Adresă bibliotecă" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextMuted}" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock x:Name="lblAdresa" Grid.Column="1"
                           Foreground="{DynamicResource TextPrimary}" FontSize="13" VerticalAlignment="Center"/>
                            </Grid>
                            <Separator Background="{DynamicResource BorderBrushLight}" Margin="0,4,0,10"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Telefon contact" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextMuted}" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock x:Name="lblTelefon" Grid.Column="1"
                           Foreground="{DynamicResource TextPrimary}" FontSize="13" VerticalAlignment="Center"/>
                            </Grid>
                            <Separator Background="{DynamicResource BorderBrushLight}" Margin="0,4,0,10"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Email bibliotecă" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextMuted}" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock x:Name="lblEmailBiblioteca" Grid.Column="1"
                           Foreground="{DynamicResource TextPrimary}" FontSize="13" VerticalAlignment="Center"/>
                            </Grid>
                            <Separator Background="{DynamicResource BorderBrushLight}" Margin="0,4,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Website" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextMuted}" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock x:Name="lblWebsite" Grid.Column="1"
                           Foreground="{DynamicResource TextPrimary}" FontSize="13" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel x:Name="pnlGeneralEdit" Visibility="Collapsed">
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Nume bibliotecă / instituție" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="txtDenumireInstitutie" Height="36" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="Adresă" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="txtAdresa" Height="36" VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Telefon contact" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="txtTelefonContact" Height="36" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="8,0,8,0">
                                    <TextBlock Text="Email bibliotecă" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="txtEmailBiblioteca" Height="36" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                    <TextBlock Text="Website" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="txtWebsite" Height="36" VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>


                <Border Background="{DynamicResource CardBackground}" CornerRadius="12" BorderBrush="{DynamicResource BorderBrushLight}"
        BorderThickness="1" Padding="25" Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,18">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="36" Height="36" CornerRadius="8"
                        Background="{DynamicResource ReservedPurpleBg}" Margin="0,0,12,0">
                                    <fa5:ImageAwesome Icon="Solid_Palette" Width="16" Foreground="{DynamicResource ReservedPurple}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Personalizare Aspect" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBlock Text="Schimbă tema vizuală și culorile de accent ale interfeței."
                               Foreground="{DynamicResource TextMuted}" FontSize="12"/>
                                </StackPanel>
                            </StackPanel>

                            <Button x:Name="btnEditTheme" HorizontalAlignment="Right"
                    Width="110" Height="34"
                    Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1"
                    Cursor="Hand" Click="BtnEditTheme_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                                <StackPanel Orientation="Horizontal">
                                    <fa5:ImageAwesome Icon="Solid_Pen" Width="12" Foreground="{DynamicResource ReservedPurple}" Margin="0,0,7,0"/>
                                    <TextBlock Text="Editează" Foreground="{DynamicResource ReservedPurple}" FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <StackPanel x:Name="pnlThemeView">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Tematică activă" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" FontSize="13" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="12" Height="12" CornerRadius="6" Background="{DynamicResource TotalBlue}" x:Name="themeIndicatorColor" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="lblActiveTheme" Text="Light Theme" Foreground="{DynamicResource TextSecondary}" FontSize="13" FontWeight="Medium"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <StackPanel x:Name="pnlThemeEdit" Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Alege tematica vizuală" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox x:Name="cmbThemeSelection" Height="38" VerticalContentAlignment="Center" Padding="10,0">
                                        <ComboBoxItem Content="Light Theme" IsSelected="True"/>
                                        <ComboBoxItem Content="Dark Theme"/>
                                        <ComboBoxItem Content="Emerald Reading (Oază Verde)"/>
                                        <ComboBoxItem Content="Royal Amethyst (Ediție Colecție)"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource CardBackground}" CornerRadius="12" BorderBrush="{DynamicResource BorderBrushLight}"
        BorderThickness="1" Padding="25" Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,18">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="36" Height="36" CornerRadius="8"
                        Background="{DynamicResource TotalBlueBg}" Margin="0,0,12,0">
                                    <fa5:ImageAwesome Icon="Solid_Envelope" Width="16" Foreground="{DynamicResource TotalBlue}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="SMTP" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBlock Text="Configurare server pentru trimiterea emailurilor."
                               Foreground="{DynamicResource TextMuted}" FontSize="12"/>
                                </StackPanel>
                            </StackPanel>

                            <Button x:Name="btnEditSmtp" HorizontalAlignment="Right"
                    Width="110" Height="34"
                    Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1"
                    Cursor="Hand" Click="BtnEditSmtp_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                                <StackPanel Orientation="Horizontal">
                                    <fa5:ImageAwesome Icon="Solid_Pen" Width="12" Foreground="{DynamicResource TotalBlue}" Margin="0,0,7,0"/>
                                    <TextBlock Text="Editează" Foreground="{DynamicResource TotalBlue}" FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <StackPanel x:Name="pnlSmtpView">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Server SMTP" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock x:Name="lblSmtpServer" Grid.Column="1" Foreground="{DynamicResource TextPrimary}" FontSize="13" VerticalAlignment="Center"/>
                            </Grid>
                            <Separator Background="{DynamicResource BorderBrushLight}" Margin="0,4,0,10"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Port SMTP" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock x:Name="lblSmtpPort" Grid.Column="1" Foreground="{DynamicResource TextPrimary}" FontSize="13" VerticalAlignment="Center"/>
                            </Grid>
                            <Separator Background="{DynamicResource BorderBrushLight}" Margin="0,4,0,10"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Email expeditor" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock x:Name="lblSmtpEmail" Grid.Column="1" Foreground="{DynamicResource TextPrimary}" FontSize="13" VerticalAlignment="Center"/>
                            </Grid>
                            <Separator Background="{DynamicResource BorderBrushLight}" Margin="0,4,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Parolă aplicație*" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock x:Name="lblSmtpParola" Text="●●●● ●●●● ●●●● ●●●●"
                           Grid.Column="1" Foreground="{DynamicResource TextPrimary}" FontSize="13" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel x:Name="pnlSmtpEdit" Visibility="Collapsed">
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Server SMTP" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="txtSmtpServer" Height="36" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="Port" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="txtSmtpPort" Height="36" VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Email expeditor" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="txtSmtpEmail" Height="36" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="Parolă aplicație" Style="{StaticResource FieldLabel}"/>
                                    <PasswordBox x:Name="txtSmtpParola" Height="36"
                                 VerticalContentAlignment="Center"
                                 BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1"
                                 Padding="8,0"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>


                <Border Background="{DynamicResource CardBackground}" CornerRadius="12" BorderBrush="{DynamicResource BorderBrushLight}"
        BorderThickness="1" Padding="25" Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,18">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="36" Height="36" CornerRadius="8"
                        Background="{DynamicResource TotalBlueBg}" Margin="0,0,12,0">
                                    <fa5:ImageAwesome Icon="Solid_Cogs" Width="16" Foreground="{DynamicResource TotalBlue}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Setări aplicație" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBlock Text="Parametri și reguli de funcționare."
                               Foreground="{DynamicResource TextMuted}" FontSize="12"/>
                                </StackPanel>
                            </StackPanel>

                            <Button x:Name="btnEditApp" HorizontalAlignment="Right"
                    Width="110" Height="34"
                    Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1"
                    Cursor="Hand" Click="BtnEditApp_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                                <StackPanel Orientation="Horizontal">
                                    <fa5:ImageAwesome Icon="Solid_Pen" Width="12" Foreground="{DynamicResource TotalBlue}" Margin="0,0,7,0"/>
                                    <TextBlock Text="Editează" Foreground="{DynamicResource TotalBlue}" FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <StackPanel x:Name="pnlAppView">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="260"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Durată împrumut carte (zile)" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock x:Name="lblDurataImprumut" Grid.Column="1" Foreground="{DynamicResource TextPrimary}" FontSize="13" VerticalAlignment="Center"/>
                            </Grid>
                            <Separator Background="{DynamicResource BorderBrushLight}" Margin="0,4,0,10"/>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="260"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Max. împrumuturi per elev" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock x:Name="lblMaxImprumuturi" Grid.Column="1" Foreground="{DynamicResource TextPrimary}" FontSize="13" VerticalAlignment="Center"/>
                            </Grid>
                            <Separator Background="{DynamicResource BorderBrushLight}" Margin="0,4,0,10"/>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="260"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Durată rezervare (zile)" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock x:Name="lblDurataRezervare" Grid.Column="1" Foreground="{DynamicResource TextPrimary}" FontSize="13" VerticalAlignment="Center"/>
                            </Grid>
                            <Separator Background="{DynamicResource BorderBrushLight}" Margin="0,4,0,10"/>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="260"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Durată împrumut manual (luni)" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock x:Name="lblDurataManual" Grid.Column="1" Foreground="{DynamicResource TextPrimary}" FontSize="13" VerticalAlignment="Center"/>
                            </Grid>
                            <Separator Background="{DynamicResource BorderBrushLight}" Margin="0,4,0,10"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="260"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Penalizare întârziere per zi (MDL)" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock x:Name="lblPenalizare" Grid.Column="1" Foreground="{DynamicResource TextPrimary}" FontSize="13" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel x:Name="pnlAppEdit" Visibility="Collapsed">
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Durată împrumut carte (zile)" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="txtDurataImprumut" Height="36" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="8,0,8,0">
                                    <TextBlock Text="Max. împrumuturi per elev" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="txtMaxImprumuturi" Height="36" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                    <TextBlock Text="Durată rezervare (zile)" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="txtDurataRezervare" Height="36" VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Durată împrumut manual (luni)" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="txtDurataManual" Height="36" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="Penalizare întârziere per zi (MDL)" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="txtPenalizare" Height="36" VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>


                <Border Background="{DynamicResource CardBackground}" CornerRadius="12" BorderBrush="{DynamicResource BorderBrushLight}"
        BorderThickness="1" Padding="25" Margin="0,0,0,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                            <Border Width="36" Height="36" CornerRadius="8"
                    Background="{DynamicResource TotalBlueBg}" Margin="0,0,12,0">
                                <fa5:ImageAwesome Icon="Solid_FileAlt" Width="16" Foreground="{DynamicResource TotalBlue}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Template-uri email" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Gestionează template-urile de email folosite în sistem."
                           Foreground="{DynamicResource TextMuted}" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>

                        <Border BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="0,0,0,1" Padding="0,0,0,14" Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Atenționare întârziere" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondary}" FontSize="13"/>
                                    <TextBlock Text="Notificare pentru cărți întârziate la returnare."
                               Foreground="{DynamicResource TextMuted}" FontSize="12"/>
                                </StackPanel>

                                <Button Grid.Column="1" Width="110" Height="34" 
                        Background="{DynamicResource CardBackground}" 
                        BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1"
                        Cursor="Hand">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>

<UserControl x:Class="BibliotecaCEITI.Settings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             xmlns:local="clr-namespace:BibliotecaCEITI"
             mc:Ignorable="d" 
             Background="{DynamicResource WindowBackground}"
             FontFamily="Segoe UI" d:Height="600" d:DesignWidth="1000">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="DefaultControls.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="0,0,0,25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="Transparent" Padding="40,30,40,10">
            <Grid>
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock Text="Setările sistemului" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="Gestionare profil" Foreground="{DynamicResource TextMuted}" FontSize="14" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,5">
                    <Button x:Name="btnSalveazaSetari" Width="180" Height="38" Style="{StaticResource GlobalActionButtonStyle}" Click="btnSalveazaSetari_Click">
                        <StackPanel Orientation="Horizontal">
                            <fa5:ImageAwesome Icon="Solid_Check" Width="14" Foreground="White" Margin="0,0,10,0"/>
                            <TextBlock Text="Salvează modificările"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="40,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,30,0">
                    <Border CornerRadius="12" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderLight}" BorderThickness="1" Padding="25">
                        <StackPanel>
                            <TextBlock Text="Imagine Profil / Logo" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,20"/>

                            <Border Width="200" Height="200" CornerRadius="100" Background="{DynamicResource WindowBackground}" BorderBrush="{DynamicResource BorderLight}" BorderThickness="2" HorizontalAlignment="Center" Margin="0,0,0,20">
                                <Border.Clip>
                                    <EllipseGeometry Center="100,100" RadiusX="100" RadiusY="100"/>
                                </Border.Clip>
                                <Image x:Name="imgSettingsLogo" Stretch="UniformToFill" />
                            </Border>

                            <Button Background="{DynamicResource WindowBackground}" BorderThickness="0" Height="40" Cursor="Hand" Click="btnUploadImage_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                                <StackPanel Orientation="Horizontal">
                                    <fa5:ImageAwesome Icon="Solid_Camera" Width="14" Margin="0,0,10,0" Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBlock Text="Schimbă Imaginea" Foreground="{DynamicResource TextPrimary}" FontWeight="Medium"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,0,64">
                    <Border Background="{DynamicResource CardBackground}" CornerRadius="12" BorderBrush="{DynamicResource BorderLight}" BorderThickness="1" Padding="25" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Informații Generale" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,20"/>

                            <TextBlock Text="Nume profilului" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtInstitutie" Margin="0,0,0,15" Height="38" VerticalContentAlignment="Center" Text="Biblioteca CEITI"/>

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Email Contact" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="txtEmail" Height="38" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Telefon" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="txtTelefon" Height="38" VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource CardBackground}" CornerRadius="12" BorderBrush="{DynamicResource BorderLight}" BorderThickness="1" Padding="25">
                        <StackPanel>
                            <TextBlock Text="Informații Cont" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,20"/>

                            <UniformGrid Columns="2">
                                <StackPanel Orientation="Horizontal" Margin="0,0,10,15">
                                    <TextBlock Text="Data ultimei logări:" Style="{StaticResource FieldLabel}" FontWeight="Bold"/>
                                    <TextBlock x:Name="lblLastLogin" Text=" 12.05.2026" Foreground="#4483EC" Margin="5,0,0,0"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="10,0,0,15">
                                    <TextBlock Text="Data creării contului:" Style="{StaticResource FieldLabel}" FontWeight="Bold"/>
                                    <TextBlock x:Name="lblCreatedAt" Text=" 01.09.2023" Foreground="#4483EC" Margin="5,0,0,0"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                                    <TextBlock Text="Nr de împrumuturi confirmate:" Style="{StaticResource FieldLabel}" FontWeight="Bold"/>
                                    <TextBlock x:Name="lblLoanCount" Text=" 15" Foreground="#4483EC" Margin="5,0,0,0" Height="33"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                                    <TextBlock Text="Nr de zile de la conectare:" Style="{StaticResource FieldLabel}" FontWeight="Bold"/>
                                    <TextBlock x:Name="lblFine" Text="12 zile" Foreground="#4483EC" Margin="5,0,0,0"/>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
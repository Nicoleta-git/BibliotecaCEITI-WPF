<UserControl x:Class="BibliotecaCEITI.CheckInBorrowSept_4"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BibliotecaCEITI"
             mc:Ignorable="d" Background="#F4F7FE"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <StackPanel Grid.Row="0" Margin="25">
            <Border BorderBrush="#d7d8de" BorderThickness="0,0,0,2">
                <TextBlock Text="4. Confirmă împrumut" FontSize="20" FontWeight="Bold" Padding="10"/>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Height="300">
            <Border Padding="30,30,30,0" Width="394" BorderBrush="#d7d8de" BorderThickness="0,0,2,0">
                <StackPanel Height="324" Margin="6,0,-32,0">
                    <TextBlock Text="Elev" FontWeight="bold" FontSize="18" Foreground="#303030" Margin="0,0,0,30"/>
                    <TextBlock Text="Nume" Foreground="#707070" FontSize="12"/>
                    <TextBlock x:Name="nume_elev" Text="Tite Nicoleta" FontSize="16" Foreground="#303030" Margin="0,0,0,15"/>
                    <TextBlock Text="Clasa" Foreground="#707070" FontSize="12"/>
                    <TextBlock x:Name="clasa_elev" Text="XII" FontSize="16" Foreground="#303030" Margin="0,0,0,15"/>
                    <TextBlock Text="ID Elev" Foreground="#707070" FontSize="12"/>
                    <TextBlock x:Name="id_elev" Text="8978724" FontSize="16" Foreground="#303030" Margin="0,0,0,15"/>
                    <TextBlock Text="Telefon" Foreground="#707070" FontSize="12"/>
                    <TextBlock x:Name="telefon_elev" Text="072 434 375" FontSize="16" Foreground="#303030" Margin="0,0,0,15"/>
                </StackPanel>
            </Border>
            <Border Padding="30,30,30,0" Height="343" Width="399">
                <StackPanel Width="710" Margin="0,0,0,57">
                    <TextBlock Text="Carte" FontWeight="bold" FontSize="18" Foreground="#303030" Margin="0,0,0,30"/>
                    <TextBlock Text="Titlu" Foreground="#707070" FontSize="12"/>
                    <TextBlock x:Name="titlu_carte" Text="Amintiri din copilarie" FontSize="16" Foreground="#303030" Margin="0,0,0,15"/>
                    <TextBlock Text="Autor" Foreground="#707070" FontSize="12"/>
                    <TextBlock x:Name="autor_carte" Text="Ion Creanga" FontSize="16" Foreground="#303030" Margin="0,0,0,15"/>
                    <TextBlock Text="ISBN" Foreground="#707070" FontSize="12"/>
                    <TextBlock x:Name="isbn_carte" Text="746-4636-654" FontSize="16" Foreground="#303030" Margin="0,0,0,15"/>
                    <TextBlock Text="Termen de returnare" Foreground="#707070" FontSize="12"/>
                    <TextBlock x:Name="termen_returnare" Text="04.06.2025 (14 zile)" FontSize="16" Foreground="#303030" Margin="0,0,0,15"/>
                </StackPanel>
            </Border>
        </StackPanel>

    </Grid>
</UserControl>

<UserControl x:Class="BibliotecaCEITI.AddStudent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BibliotecaCEITI"
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             mc:Ignorable="d" 
             Background="{DynamicResource WindowBackground}"
             FontFamily="Segoe UI"
             d:DesignHeight="470" d:DesignWidth="800">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="DefaultControls.xaml"/>
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="Transparent" Padding="15,30,40,20">
            <Grid>
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Button x:Name="btnBack" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnBack_Click" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <fa5:ImageAwesome Icon="Solid_ArrowLeft" Width="10" Margin="0,0,8,0" Foreground="{DynamicResource PrimaryBlue}"/>
                            <TextBlock Text="Înapoi la listă" Foreground="{DynamicResource PrimaryBlue}" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <TextBlock Text="Adauga Elev" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,5">
                    <Button Content="Anulează" Width="100" Height="38" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0" Click="Button_Click_1"/>
                    <Button x:Name="btnAddStudent" Width="200" Height="38" Style="{StaticResource GlobalActionButtonStyle}" Click="btnSalveazaModificari_Click">
                        <StackPanel Orientation="Horizontal">
                            <fa5:ImageAwesome Icon="Solid_Save" Width="14" Foreground="White" Margin="0,0,10,0"/>
                            <TextBlock Text="Salvează Elev"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,10,20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,30,20">
                    <Border CornerRadius="12" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Informații Identificare" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,15"/>

                            <TextBlock Text="IDNP (13 cifre) *" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtIdnp" Background="Transparent" Height="38" VerticalContentAlignment="Center" MaxLength="13" Margin="0,0,0,15" GotFocus="txtIdnp_GotFocus" LostFocus="txtIdnp_LostFocus" PreviewTextInput="txtIdnp_PreviewTextInput"/>

                            <TextBlock Text="Grupă *" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="cbGrupe" Background="Transparent" Foreground="{DynamicResource TextPrimary}" Height="38" DisplayMemberPath="Denumire" SelectedValuePath="Id" Margin="0,0,0,15"/>

                            <TextBlock Text="Data Nașterii" Style="{StaticResource FieldLabel}"/>
                            <DatePicker x:Name="dpDataNasterii" Background="Transparent" Height="38" Style="{StaticResource ModernDatePicker}" Margin="0,0,0,5"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,0,20">
                    <Border Background="{DynamicResource CardBackground}" CornerRadius="12" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1" Padding="25">
                        <StackPanel>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Nume *" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="txtNume" Background="Transparent" Height="38" VerticalContentAlignment="Center" GotFocus="txtNume_GotFocus" LostFocus="txtNume_LostFocus"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Prenume *" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="txtPrenume" Background="Transparent" Height="38" VerticalContentAlignment="Center" GotFocus="txtPrenume_GotFocus" LostFocus="txtPrenume_LostFocus"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Telefon" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="txtTelefon" Background="Transparent" Height="38" VerticalContentAlignment="Center" GotFocus="txtTelefon_GotFocus" LostFocus="txtTelefon_LostFocus" PreviewTextInput="txtTelefon_PreviewTextInput"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Email" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="txtEmail" Background="Transparent" Height="38" VerticalContentAlignment="Center" GotFocus="txtEmail_GotFocus" LostFocus="txtEmail_LostFocus"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Observații" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtObservatii" Background="Transparent" Height="80" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="10" GotFocus="txtObservatii_GotFocus" LostFocus="txtObservatii_LostFocus"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,10,0,25"/>
                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,30"/>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
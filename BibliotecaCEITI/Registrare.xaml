<Window x:Class="BibliotecaCEITI.Registrare"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inregistrare Biblioteca" Height="600" Width="850"
        WindowStyle="None" AllowsTransparency="True" 
        Background="Transparent" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#6a11cb"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="22" Background="{TemplateBinding Background}" BorderThickness="0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" Direction="270" Opacity="0.3" ShadowDepth="5" Color="#6a11cb"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2575fc"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernInputStyle" TargetType="Control">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Background" Value="#F5F6F7"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Control">
                        <Border x:Name="InputBorder" CornerRadius="8" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="10,0" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="#6a11cb"/>
                                <Setter TargetName="InputBorder" Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="30" Background="White">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" Direction="0" Opacity="0.2" ShadowDepth="0"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="0*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="30,0,0,30" ClipToBounds="True" Grid.ColumnSpan="2" Margin="0,0,515,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#6a11cb" Offset="0"/>
                        <GradientStop Color="#2575fc" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <Ellipse Width="200" Height="200" Fill="White" Opacity="0.1" Margin="-100,-100,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>

                    <Image Source="/Assets/Logo_bib.png" 
                           Width="342" Height="196" 
                           HorizontalAlignment="Left" VerticalAlignment="Top" 
                           Margin="11,100,0,0" Opacity="0.9"
                           RenderOptions.BitmapScalingMode="HighQuality"/>

                    <StackPanel VerticalAlignment="Center" Margin="30">
                        <TextBlock Text="Creează Cont" Foreground="White" FontSize="32" FontWeight="ExtraBold" HorizontalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="5" ShadowDepth="3" Opacity="0.3"/>
                            </TextBlock.Effect>
                        </TextBlock>

                        <Separator Width="40" Height="4" Background="White" Margin="0,15"/>

                        <TextBlock Text="Alătură-te comunității noastre și explorează mii de cărți disponibile." 
                                   Foreground="#E0E0E0" FontSize="15" TextWrapping="Wrap" TextAlignment="Center" Margin="10,0"/>
                    </StackPanel>

                    <Ellipse Width="150" Height="150" Fill="White" Opacity="0.1" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-40,-40"/>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="50,30,50,5">
                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" 
                        Background="Transparent" BorderThickness="0" Foreground="#CCC" 
                        FontSize="20" Cursor="Hand" Margin="0,-10,-20,0" Click="ExitBtn"/>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Înregistrare" Foreground="#333" FontSize="28" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock Text="Completează datele pentru a te înscrie" Foreground="#999" FontSize="13" Margin="0,0,0,25"/>

                    <TextBlock Text="Nume Complet" Foreground="#666" Margin="0,0,0,5" FontWeight="Medium"/>
                    <TextBox Style="{StaticResource ModernInputStyle}" Margin="0,0,0,15"/>

                    <TextBlock Text="Email" Foreground="#666" Margin="0,0,0,5" FontWeight="Medium"/>
                    <TextBox Style="{StaticResource ModernInputStyle}" Margin="0,0,0,15"/>

                    <TextBlock Text="Utilizator" Foreground="#666" Margin="0,0,0,5" FontWeight="Medium"/>
                    <TextBox Style="{StaticResource ModernInputStyle}" Margin="0,0,0,15"/>

                    <TextBlock Text="Parolă" Foreground="#666" Margin="0,0,0,5" FontWeight="Medium"/>
                    <PasswordBox Style="{StaticResource ModernInputStyle}" Margin="0,0,0,10"/>

                    <CheckBox Content="Vezi parola" Margin="0,0,0,25" Foreground="#999" FontSize="11"/>

                    <Button Content="CREEAZĂ CONT" Height="45" Style="{StaticResource ModernButtonStyle}"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <TextBlock Text="Ai deja un cont?" Foreground="#999"/>
                        <TextBlock Text=" Autentifică-te" Foreground="#2575fc" FontWeight="SemiBold" Cursor="Hand" Margin="5,0,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="TextDecorations" Value="Underline"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
<UserControl x:Class="BibliotecaCEITI.BookDetails"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             mc:Ignorable="d"
             Background="{DynamicResource WindowBackground}" 
             FontFamily="Segoe UI" d:DesignWidth="1000" Height="741">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="0,0,0,25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="Transparent" Padding="40,30,40,10">
            <Grid>
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Button x:Name="btnBack" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnBack_Click" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <fa5:ImageAwesome Icon="Solid_ArrowLeft" Width="10" Margin="0,0,8,0" Foreground="#4483EC"/>
                            <TextBlock Text="Înapoi la listă" Foreground="#4483EC" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <TextBlock x:Name="action_book" Text="Editare detalii carte" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,5">
                    <Button Content="Anulează" Width="100" Height="38" Background="{DynamicResource CardBackground}" Foreground="{DynamicResource TextPrimary}" BorderBrush="{DynamicResource BorderBrushLight}" Margin="0,0,10,0" Click="Button_Click_1">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="btnSalveazaModificari" Width="200" Height="38" Style="{StaticResource GlobalActionButtonStyle}" Click="btnSalveazaModificari_Click">
                        <StackPanel Orientation="Horizontal">
                            <fa5:ImageAwesome Icon="Solid_Save" Width="14" Foreground="White" Margin="0,0,10,0"/>
                            <TextBlock Text="Salvează modificările" Foreground="White"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Height="694" VerticalAlignment="Top">
            <Grid Margin="40,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,30,0">
                    <Border CornerRadius="12" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Coperta curentă" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,15"/>
                            <Border Height="380" CornerRadius="8" Background="{DynamicResource WindowBackground}" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1" Margin="0,0,0,15">
                                <Image x:Name="imgCoperta" Stretch="Uniform"/>
                            </Border>
                            <Button Background="{DynamicResource WindowBackground}" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1" Height="36" Cursor="Hand" Click="Button_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                                <StackPanel Orientation="Horizontal">
                                    <fa5:ImageAwesome Icon="Solid_Upload" Width="12" Margin="0,0,8,0" Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBlock x:Name="incarca_imagine" Text="Încarcă altă imagine" Foreground="{DynamicResource TextPrimary}" FontWeight="Medium"/>
                                </StackPanel>
                            </Button>
                            <TextBlock Text="URL Imagine" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,20,0,8"/>
                            <TextBox x:Name="txtCopertaUrl" FontSize="11" VerticalContentAlignment="Center" Height="35" IsReadOnly="True" Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource TextPrimary}" BorderBrush="{DynamicResource BorderBrushLight}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <Border Background="{DynamicResource CardBackground}" CornerRadius="12" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1" Padding="25">
                        <StackPanel>
                            <TextBlock Text="Titlu carte *" Style="{StaticResource FieldLabel}" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBox x:Name="txtTitlu" Margin="0,0,0,15" Height="38" VerticalContentAlignment="Center" Background="Transparent" Foreground="{DynamicResource TextPrimary}" BorderBrush="{DynamicResource BorderBrushLight}" GotFocus="txtTitlu_GotFocus" LostFocus="txtTitlu_LostFocus"/>

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Autor *" Style="{StaticResource FieldLabel}" Foreground="{DynamicResource TextPrimary}"/>
                                    <StackPanel Orientation="Horizontal" Width="271">
                                        <ComboBox x:Name="cbAutor" Margin="0,0,10,0"  Height="38" Background="Transparent" Foreground="{DynamicResource TextPrimary}" BorderBrush="{DynamicResource BorderBrushLight}" SelectionChanged="cbAutor_SelectionChanged" Width="223"/>
                                        <Button Style="{StaticResource GlobalActionButtonStyle}" Width="31" Height="33">+</Button>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Categorie *" Style="{StaticResource FieldLabel}" Foreground="{DynamicResource TextPrimary}"/>
                                    <StackPanel Orientation="Horizontal">
                                        <ComboBox x:Name="cbCategorie" Margin="0,0,10,0" Height="38" Background="Transparent" Foreground="{DynamicResource TextPrimary}" BorderBrush="{DynamicResource BorderBrushLight}" SelectionChanged="cbCategorie_SelectionChanged" Width="228"/>
                                        <Button Style="{StaticResource GlobalActionButtonStyle}" Width="31" Height="33">+</Button>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Descriere" Style="{StaticResource FieldLabel}" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBox x:Name="txtDescriere" Height="100" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="10" Margin="0,0,0,20" Background="Transparent" Foreground="{DynamicResource TextPrimary}" BorderBrush="{DynamicResource BorderBrushLight}" GotFocus="txtDescriere_GotFocus" LostFocus="txtDescriere_LostFocus"/>

                            <UniformGrid Columns="2">
                                <StackPanel Margin="0,0,10,15">
                                    <TextBlock Text="ISBN" Style="{StaticResource FieldLabel}" Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBox x:Name="txtIsbn" Height="38" MaxLength="18" VerticalContentAlignment="Center" Background="Transparent" Foreground="{DynamicResource TextPrimary}" BorderBrush="{DynamicResource BorderBrushLight}" GotFocus="txtIsbn_GotFocus" LostFocus="txtIsbn_LostFocus" TextChanged="txtIsbn_TextChanged" TextInput="txtIsbn_TextInput"/>
                                </StackPanel>
                                <StackPanel Margin="10,0,0,15">
                                    <TextBlock Text="Editura" Style="{StaticResource FieldLabel}" Foreground="{DynamicResource TextPrimary}"/>
                                    <StackPanel Orientation="Horizontal">
                                        <ComboBox x:Name="cbEditura" Margin="0,0,10,0" Height="38" Background="Transparent" Foreground="{DynamicResource TextPrimary}" BorderBrush="{DynamicResource BorderBrushLight}" SelectionChanged="cbEditura_SelectionChanged" Width="231"/>
                                        <Button Style="{StaticResource GlobalActionButtonStyle}" Width="31" Height="33">+</Button>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Margin="0,0,10,15">
                                    <TextBlock Text="An publicare" Style="{StaticResource FieldLabel}" Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBox x:Name="txtAnPublicare" Height="38" MaxLength="4" VerticalContentAlignment="Center" Background="Transparent" Foreground="{DynamicResource TextPrimary}" BorderBrush="{DynamicResource BorderBrushLight}" GotFocus="txtAnPublicare_GotFocus" LostFocus="txtAnPublicare_LostFocus" PreviewTextInput="txtAnPublicare_PreviewTextInput" TextChanged="txtAnPublicare_TextChanged"/>
                                </StackPanel>
                                <StackPanel Margin="10,0,0,15">
                                    <TextBlock Text="Limba" Style="{StaticResource FieldLabel}" Foreground="{DynamicResource TextPrimary}"/>
                                    <ComboBox x:Name="cbLimba" Height="38" Background="Transparent" Foreground="{DynamicResource TextPrimary}" BorderBrush="{DynamicResource BorderBrushLight}" SelectionChanged="cbLimba_SelectionChanged"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Preț Vânzare (MDL)" Style="{StaticResource FieldLabel}" Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBox x:Name="txtPretMdl" Height="38" VerticalContentAlignment="Center" Background="Transparent" Foreground="{DynamicResource TextPrimary}" BorderBrush="{DynamicResource BorderBrushLight}" GotFocus="txtPretMdl_GotFocus" LostFocus="txtPretMdl_LostFocus" PreviewTextInput="txtPretMdl_PreviewTextInput" TextChanged="txtPretMdl_TextChanged"/>
                                </StackPanel>
                                <StackPanel Margin="10,0,0,0">
                                    <TextBlock Text="Preț Chirie" Style="{StaticResource FieldLabel}" Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBox x:Name="txtPretChirie" Height="38" VerticalContentAlignment="Center" Background="Transparent" Foreground="{DynamicResource TextPrimary}" BorderBrush="{DynamicResource BorderBrushLight}" GotFocus="txtPretChirie_GotFocus" LostFocus="txtPretChirie_LostFocus" PreviewTextInput="txtPretChirie_PreviewTextInput" TextChanged="txtPretChirie_TextChanged"/>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
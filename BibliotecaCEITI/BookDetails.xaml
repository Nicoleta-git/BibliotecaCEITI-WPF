<UserControl x:Class="BibliotecaCEITI.BookDetails"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             mc:Ignorable="d"
             Background="#F4F7FE" 
             FontFamily="Segoe UI" d:DesignWidth="1000" Height="741">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="DefaultControls.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="0,0,0,25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header Section -->
            <RowDefinition Height="*"/>
            <!-- Main Content Section -->
        </Grid.RowDefinitions>

        <!-- TOP NAVIGATION & ACTIONS HEADER -->
        <Border Grid.Row="0" Background="Transparent" Padding="40,30,40,10">
            <Grid>
                <!-- Title and Return link -->
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Button x:Name="btnBack" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnBack_Click" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <fa5:ImageAwesome Icon="Solid_ArrowLeft" Width="10" Margin="0,0,8,0" Foreground="#4483EC"/>
                            <TextBlock Text="Înapoi la listă" Foreground="#4483EC" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <TextBlock Text="Editare detalii carte" FontSize="28" FontWeight="Bold" Foreground="#1B2559" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Primary Action Buttons (Cancel / Save) -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,5">
                    <Button Content="Anulează" Width="100" Height="38" Background="White" Margin="0,0,10,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="btnSalveazaModificari" Width="200" Height="38" Style="{StaticResource PrimaryButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <fa5:ImageAwesome Icon="Solid_Save" Width="14" Foreground="White" Margin="0,0,10,0"/>
                            <TextBlock Text="Salvează modificările"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Height="694" VerticalAlignment="Top">
            <Grid Margin="40,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <!-- Left Column: Book Cover -->
                    <ColumnDefinition Width="*"/>
                    <!-- Right Column: Forms & Details -->
                </Grid.ColumnDefinitions>

                <!-- BOOK COVER MANAGEMENT -->
                <StackPanel Grid.Column="0" Margin="0,0,30,0">
                    <Border CornerRadius="12" Background="White" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Coperta curentă" FontWeight="SemiBold" Foreground="#1B2559" Margin="0,0,0,15"/>
                            <!-- Image Preview Container -->
                            <Border Height="380" CornerRadius="8" Background="#F8FAFC" Margin="0,0,0,15">
                                <Image x:Name="imgCoperta" Stretch="Uniform"/>
                            </Border>
                            <!-- Cover Actions -->
                            <Button Background="#F1F5F9" BorderThickness="0" Height="36" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                                <StackPanel Orientation="Horizontal">
                                    <fa5:ImageAwesome Icon="Solid_Upload" Width="12" Margin="0,0,8,0" Foreground="#1B2559"/>
                                    <TextBlock Text="Încarcă altă imagine" Foreground="#1B2559" FontWeight="Medium"/>
                                </StackPanel>
                            </Button>
                            <!-- Cover URL Link -->
                            <TextBlock Text="URL Imagine" FontWeight="SemiBold" Foreground="#1B2559" Margin="0,20,0,8"/>
                            <TextBox x:Name="txtCopertaUrl" FontSize="11" VerticalContentAlignment="Center" Height="35"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- MAIN DATA FORM -->
                <StackPanel Grid.Column="1">
                    <Border Background="White" CornerRadius="12" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" Padding="25">
                        <StackPanel>
                            <!-- TOP FORM: Basic Information -->
                            <TextBlock Text="Titlu carte *" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtTitlu" Margin="0,0,0,15" Height="38" VerticalContentAlignment="Center"/>

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Autor *" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox x:Name="cbAutor" DisplayMemberPath="Nume" Height="38"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Categorie *" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox x:Name="cbCategorie" Height="38"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Descriere" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtDescriere" Height="100" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="10" Margin="0,0,0,20"/>

                            <!-- BOTTOM FORM: Technical Details & Pricing -->
                            <UniformGrid Columns="2">
                                <StackPanel Margin="0,0,10,15">
                                    <TextBlock Text="ISBN" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="txtIsbn" Height="38" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Margin="10,0,0,15">
                                    <TextBlock Text="Editura" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox x:Name="cbEditura" Height="38"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,10,15">
                                    <TextBlock Text="An publicare" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="txtAnPublicare" Height="38" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Margin="10,0,0,15">
                                    <TextBlock Text="Limba" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox x:Name="cbLimba" Height="38"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Preț Vânzare (MDL)" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="txtPretMdl" Height="38" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Margin="10,0,0,0">
                                    <TextBlock Text="Preț Chirie" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="txtPretChirie" Height="38" VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
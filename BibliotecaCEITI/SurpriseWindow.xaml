<Window x:Class="NumeleProiectuluiTau.SurpriseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa5="http://schemas.fontawesome.com/icons/"
        Title="La mulți ani!" Height="450" Width="650"
        WindowStartupLocation="CenterOwner" 
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent">

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="MainCard" 
                                     Storyboard.TargetProperty="Opacity" 
                                     From="0" To="1" Duration="0:0:1.5" />

                    <DoubleAnimation Storyboard.TargetName="ScaleTransform" 
                                     Storyboard.TargetProperty="ScaleX" 
                                     From="0.5" To="1" Duration="0:0:1" 
                                     >
                        <DoubleAnimation.EasingFunction>
                            <BounceEase Bounces="2" Bounciness="2" EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="ScaleTransform" 
                                     Storyboard.TargetProperty="ScaleY" 
                                     From="0.5" To="1" Duration="0:0:1" >
                        <DoubleAnimation.EasingFunction>
                            <BounceEase Bounces="2" Bounciness="2" EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Border x:Name="MainCard" Background="White" CornerRadius="20" Margin="20" RenderTransformOrigin="0.5,0.5">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="5" Opacity="0.3"/>
            </Border.Effect>

            <Border.RenderTransform>
                <ScaleTransform x:Name="ScaleTransform" ScaleX="1" ScaleY="1" />
            </Border.RenderTransform>

            <Grid>
                <Button Content="✕" FontSize="18" FontWeight="Bold" Foreground="Gray" Background="Transparent" 
                        BorderThickness="0" HorizontalAlignment="Right" VerticalAlignment="Top" 
                        Margin="15" Width="30" Height="30" Click="CloseBtn_Click" Cursor="Hand"/>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <fa5:ImageAwesome Icon="Solid_Gift" Width="80" Foreground="#FF4081" Margin="0,0,0,20"/>

                    <TextBlock Text="LA MULȚI ANI!" 
                               FontSize="42" 
                               FontWeight="Black" 
                               Foreground="#FF4081" 
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Doamna Profesoară!" 
                               FontSize="28" 
                               FontWeight="SemiBold" 
                               Foreground="#333333" 
                               HorizontalAlignment="Center" 
                               Margin="0,5,0,15"/>

                    <TextBlock Text="Vă dorim o zi plină de zâmbete, bucurii și surprize frumoase!" 
                               FontSize="16" 
                               Foreground="#666666" 
                               TextWrapping="Wrap" 
                               TextAlignment="Center"
                               MaxWidth="400"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
<UserControl x:Class="BibliotecaCEITI.Attention"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Stil paginator butoane -->
            <Style x:Key="PageButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="32"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="Margin" Value="3,0"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Background" Value="White"/>
                <Setter Property="Foreground" Value="#374151"/>
                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#F3F4F6"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="ActivePageButtonStyle" TargetType="Button" BasedOn="{StaticResource PageButtonStyle}">
                <Setter Property="Background" Value="#6210CC"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderBrush" Value="#6210CC"/>
            </Style>

            <!-- Stil header coloana tabel -->
            <Style x:Key="ColHeaderStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#6B7280"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundGray}">
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Row 0: Header -->
                <RowDefinition Height="Auto"/>
                <!-- Row 1: Stat Cards -->
                <RowDefinition Height="Auto"/>
                <!-- Row 2: Filter Bar -->
                <RowDefinition Height="*"/>
                <!-- Row 3: Tabel + Actiuni -->
            </Grid.RowDefinitions>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- ROW 0 — HEADER                                      -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Grid Grid.Row="0" Margin="10,0,10,20">
                <StackPanel>
                    <TextBlock Text="Atenționări" FontSize="26" FontWeight="Bold"
                               Foreground="{StaticResource TextDark}"/>
                    <TextBlock Text="Gestionează și trimite notificări email către elevi cu întârzieri"
                               Foreground="{StaticResource TextGray}" FontSize="13" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Dreapta: buton Reîncarcă + badge -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <!-- Badge număr întârzieri active -->
                    <Border x:Name="bdgIntarzieri" Background="#FEF2F2" CornerRadius="20"
                            Padding="14,6" Margin="0,0,12,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <fa5:ImageAwesome Icon="Solid_ExclamationTriangle" Width="13"
                                             Foreground="#EF4444" Margin="0,0,6,0"
                                             VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtBadgeIntarzieri" Text="0 întârzieri active"
                                       Foreground="#EF4444" FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Buton Reîncarcă -->
                    <Button x:Name="btnReincarca" Click="BtnReincarca_Click"
                            Style="{StaticResource ActionButtonStyle}"
                            Background="#EEF2FF" Foreground="#6210CC" Height="38">
                        <StackPanel Orientation="Horizontal">
                            <fa5:ImageAwesome Icon="Solid_SyncAlt" Width="13" Foreground="#6210CC" Margin="0,0,8,0"
                                             VerticalAlignment="Center"/>
                            <TextBlock Text="Reîncarcă" FontWeight="SemiBold" FontSize="13"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- ROW 1 — STAT CARDS                                  -->
            <!-- ═══════════════════════════════════════════════════ -->
            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,16">

                <!-- Card 1: Întârzieri -->
                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="45" Height="45" Background="#FFF5EB" CornerRadius="12" Margin="0,0,15,0">
                            <fa5:ImageAwesome Icon="Solid_ExclamationTriangle" Foreground="#FFA043"
                                             Width="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Întârzieri" Foreground="{StaticResource TextGray}" FontSize="13"/>
                            <TextBlock x:Name="txtIntarzieri" Text="—" FontSize="22" FontWeight="Bold"
                                       Foreground="#FFA043"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Card 2: Notificări trimise -->
                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="45" Height="45" Background="#EEE6FF" CornerRadius="12" Margin="0,0,15,0">
                            <fa5:ImageAwesome Icon="Solid_Envelope" Foreground="#6210CC"
                                             Width="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Notificări trimise" Foreground="{StaticResource TextGray}" FontSize="13"/>
                            <TextBlock x:Name="txtNotifTrimise" Text="—" FontSize="22" FontWeight="Bold"
                                       Foreground="#6210CC"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Card 3: În așteptare -->
                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="45" Height="45" Background="#FFF5EB" CornerRadius="12" Margin="0,0,15,0">
                            <fa5:ImageAwesome Icon="Solid_HourglassHalf" Foreground="#FFA043"
                                             Width="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="În așteptare" Foreground="{StaticResource TextGray}" FontSize="13"/>
                            <TextBlock x:Name="txtInAsteptare" Text="—" FontSize="22" FontWeight="Bold"
                                       Foreground="#FFA043"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Card 4: Rezolvate -->
                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="45" Height="45" Background="#E6F9F4" CornerRadius="12" Margin="0,0,15,0">
                            <fa5:ImageAwesome Icon="Solid_CheckCircle" Foreground="#05CD99"
                                             Width="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Rezolvate" Foreground="{StaticResource TextGray}" FontSize="13"/>
                            <TextBlock x:Name="txtRezolvate" Text="—" FontSize="22" FontWeight="Bold"
                                       Foreground="#05CD99"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- ROW 2 — FILTER BAR                                  -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Border Grid.Row="2" Background="White" CornerRadius="15"
                    Effect="{StaticResource CardShadow}" Padding="16" Margin="10,0,10,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Căutare -->
                    <Border Grid.Column="0" Background="#F8FAFC" CornerRadius="10"
                            BorderBrush="#E2E8F0" BorderThickness="1" Height="40" Margin="0,0,12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <fa5:ImageAwesome Icon="Solid_Search" Foreground="#A0AEC0" Width="14"
                                             VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <TextBox x:Name="txtSearch" Grid.Column="1" VerticalContentAlignment="Center"
                                     BorderThickness="0" Background="Transparent"
                                     Padding="4,0" FontSize="13" Foreground="{StaticResource TextDark}"
                                     TextChanged="TxtSearch_TextChanged"/>
                        </Grid>
                    </Border>

                    <!-- ComboBox Clase -->
                    <ComboBox x:Name="cbxClasa" Grid.Column="1" Width="140" Height="40" Margin="0,0,12,0"
                              FontSize="13" Background="#F8FAFC" BorderBrush="#E2E8F0"
                              SelectionChanged="CbxClasa_SelectionChanged"/>

                    <!-- ComboBox Status -->
                    <ComboBox x:Name="cbxStatus" Grid.Column="2" Width="200" Height="40" Margin="0,0,12,0"
                              FontSize="13" Background="#F8FAFC" BorderBrush="#E2E8F0"
                              SelectionChanged="CbxStatus_SelectionChanged">
                        <ComboBoxItem Content="Toate statusurile" IsSelected="True"/>
                        <ComboBoxItem Content="Întârziere &gt; 5 zile"/>
                        <ComboBoxItem Content="Întârziere 1-4 zile"/>
                    </ComboBox>

                    <!-- Buton Reset -->
                    <Button Grid.Column="3" Style="{StaticResource ActionButtonStyle}"
                            Height="40" Click="BtnReset_Click"
                            Background="#F1F5F9" Foreground="#475569">
                        <StackPanel Orientation="Horizontal">
                            <fa5:ImageAwesome Icon="Solid_Times" Width="11" Foreground="#475569"
                                             Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Reset" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- ROW 3 — TABEL + PANEL ACTIUNI                       -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Grid Grid.Row="3" Margin="10,0,10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <!-- ─── TABEL ─── -->
                <Border Grid.Column="0" Background="White" CornerRadius="15"
                        Effect="{StaticResource CardShadow}" ClipToBounds="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <!-- Header selectie -->
                            <RowDefinition Height="Auto"/>
                            <!-- Header coloane -->
                            <RowDefinition Height="*"/>
                            <!-- Rânduri -->
                            <RowDefinition Height="Auto"/>
                            <!-- Paginare -->
                        </Grid.RowDefinitions>

                        <!-- Header selectie globala -->
                        <Border Grid.Row="0" Background="#F8FAFC"
                                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="16,10">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox x:Name="chkSelectAll" VerticalAlignment="Center"
                                          Margin="0,0,10,0" Checked="ChkSelectAll_Changed"
                                          Unchecked="ChkSelectAll_Changed"/>
                                <TextBlock x:Name="txtSelectAll" Text="Selectează toate (0)"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextDark}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Header coloane -->
                        <Border Grid.Row="1" Background="#F8FAFC"
                                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="16,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"/>
                                <TextBlock Grid.Column="1" Text="ELEV" Style="{StaticResource ColHeaderStyle}"/>
                                <TextBlock Grid.Column="2" Text="CARTE" Style="{StaticResource ColHeaderStyle}"/>
                                <TextBlock Grid.Column="3" Text="TERMEN" Style="{StaticResource ColHeaderStyle}"/>
                                <TextBlock Grid.Column="4" Text="ZILE ÎNT." Style="{StaticResource ColHeaderStyle}"/>
                                <TextBlock Grid.Column="5" Text="EMAIL" Style="{StaticResource ColHeaderStyle}"/>
                                <TextBlock Grid.Column="6" Text="STATUS" Style="{StaticResource ColHeaderStyle}"/>
                            </Grid>
                        </Border>

                        <!-- Rânduri (generate dinamic) -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="spRanduri">
                                <!-- Rânduri adăugate din code-behind -->

                                <!-- Placeholder când nu sunt date -->
                                <Border x:Name="bdPlaceholder" Padding="40" Visibility="Collapsed">
                                    <StackPanel HorizontalAlignment="Center">
                                        <fa5:ImageAwesome Icon="Solid_CheckCircle" Width="48"
                                                         Foreground="#05CD99" HorizontalAlignment="Center"
                                                         Margin="0,0,0,16"/>
                                        <TextBlock Text="Nu există întârzieri active!"
                                                   FontSize="16" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextDark}"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="Toți elevii au returnat cărțile la timp."
                                                   FontSize="13" Foreground="{StaticResource TextGray}"
                                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Footer paginare -->
                        <Border Grid.Row="3" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="16,10">
                            <Grid>
                                <TextBlock x:Name="txtPaginareInfo"
                                           Text="Pagina 1 din 1 · 0 înregistrări"
                                           Foreground="{StaticResource TextGray}" FontSize="12"
                                           VerticalAlignment="Center"/>
                                <StackPanel x:Name="spPaginator" Orientation="Horizontal"
                                            HorizontalAlignment="Right">
                                    <!-- Butoanele de pagini sunt generate dinamic -->
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- ─── PANEL ACTIUNI DREAPTA ─── -->
                <StackPanel Grid.Column="1" Margin="16,0,0,0">

                    <!-- Buton Trimite notificări -->
                    <Button x:Name="btnTrimite" Style="{StaticResource GlobalActionButtonStyle}"
                            Width="Auto" Height="45" Margin="0,0,0,10"
                            Background="#6210CC"
                            Click="BtnTrimite_Click">
                        <StackPanel Orientation="Horizontal">
                            <fa5:ImageAwesome Icon="Solid_Envelope" Foreground="White" Width="14"
                                             Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtBtnTrimite" Text="Trimite notificări (0)"
                                       FontWeight="SemiBold" FontSize="13"/>
                        </StackPanel>
                    </Button>

                    <!-- Buton Previzualizează email -->
                    <Button x:Name="btnPrevizualizeaza" Style="{StaticResource ActionButtonStyle}"
                            Width="Auto" Height="40" Margin="0,0,0,10"
                            Background="#EEF2FF" Foreground="#6210CC"
                            Click="BtnPrevizualizeaza_Click">
                        <StackPanel Orientation="Horizontal">
                            <fa5:ImageAwesome Icon="Solid_Eye" Foreground="#6210CC" Width="13"
                                             Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Previzualizează email" FontWeight="SemiBold" FontSize="13"/>
                        </StackPanel>
                    </Button>

                    <!-- Buton Anulează selecția -->
                    <Button x:Name="btnAnuleaza" Style="{StaticResource DangerButtonStyle}"
                            Width="Auto" Margin="0,0,0,16"
                            Click="BtnAnuleaza_Click">
                        <StackPanel Orientation="Horizontal">
                            <fa5:ImageAwesome Icon="Solid_Times" Foreground="White" Width="12"
                                             Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Anulează selecția" FontWeight="SemiBold" FontSize="13"/>
                        </StackPanel>
                    </Button>

                    <!-- Separator -->
                    <Border BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Margin="0,0,0,16"/>

                    <!-- Previzualizare email -->
                    <Border Background="White" CornerRadius="15" Effect="{StaticResource CardShadow}"
                            Padding="16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <fa5:ImageAwesome Icon="Solid_Envelope" Width="14" Foreground="#6210CC"
                                                 Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Previzualizare email" FontWeight="Bold" FontSize="14"
                                           Foreground="{StaticResource TextDark}"/>
                            </StackPanel>

                            <RichTextBox x:Name="rtbPrevizualizare"
                                         IsReadOnly="True" BorderThickness="0"
                                         Background="Transparent" MinHeight="250"
                                         Foreground="{StaticResource TextDark}"
                                         FontSize="12" Padding="0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Overlay loading -->
        <Border x:Name="overlayLoading" Background="#88FFFFFF" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <fa5:ImageAwesome Icon="Solid_Spinner" Width="40" Foreground="#6210CC"
                                 HorizontalAlignment="Center"
                                 RenderTransformOrigin="0.5,0.5">
                    <fa5:ImageAwesome.RenderTransform>
                        <RotateTransform x:Name="spinnerRotate"/>
                    </fa5:ImageAwesome.RenderTransform>
                </fa5:ImageAwesome>
                <TextBlock x:Name="txtLoading" Text="Se trimite..." FontSize="15"
                           FontWeight="SemiBold" Foreground="#6210CC" Margin="0,12,0,0"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>


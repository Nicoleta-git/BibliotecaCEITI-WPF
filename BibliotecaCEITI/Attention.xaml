<UserControl x:Class="BibliotecaCEITI.Attention"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             mc:Ignorable="d" Background="Transparent"
             d:DesignHeight="800" d:DesignWidth="1200">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="PageButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="32"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="Margin" Value="3,0"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushLight}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="ActivePageButtonStyle" TargetType="Button" BasedOn="{StaticResource PageButtonStyle}">
                <Setter Property="Background" Value="{DynamicResource PrimaryAccent}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryAccent}"/>
            </Style>

            <Style x:Key="ColHeaderStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="ActionPanelButtonStyle" TargetType="Button">
                <Setter Property="Height" Value="40"/>
                <Setter Property="Margin" Value="0,0,0,8"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                    CornerRadius="8" Padding="12,0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="Transparent">
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="10,0,10,20">
                <StackPanel>
                    <TextBlock Text="Atenționări" FontSize="26" FontWeight="Bold"
                              Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border x:Name="bdgIntarzieri" Background="{StaticResource BorrowedOrangeBg}" CornerRadius="20"
                            Padding="14,6" Margin="0,0,12,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <fa5:ImageAwesome Icon="Solid_ExclamationTriangle" Width="13"
                                             Foreground="{StaticResource BorrowedOrange}" Margin="0,0,6,0"
                                             VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtBadgeIntarzieri" Text="0 întârzieri active"
                                       Foreground="{StaticResource BorrowedOrange}" FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Button x:Name="btnReincarca" Click="BtnReincarca_Click"
                            Style="{StaticResource ActionButtonStyle}"
                            Background="{StaticResource TotalBlueBg}" Foreground="{StaticResource TotalBlue}" Height="38">
                        <StackPanel Orientation="Horizontal">
                            <fa5:ImageAwesome Icon="Solid_SyncAlt" Width="13" Foreground="{StaticResource TotalBlue}" Margin="0,0,8,0"
                                             VerticalAlignment="Center"/>
                            <TextBlock Text="Reîncarcă" FontWeight="SemiBold" FontSize="13"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,16">

                <Border Style="{StaticResource StatCardStyle}"  Background="{DynamicResource CardBackground}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Margin="10">
                        <Border Width="45" Height="45" Background="{StaticResource BorrowedOrangeBg}" CornerRadius="12" Margin="0,0,15,0">
                            <fa5:ImageAwesome Icon="Solid_ExclamationTriangle" Foreground="{StaticResource BorrowedOrange}" Width="20"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Întârzieri" Foreground="{StaticResource TextMuted}" FontSize="13"/>
                            <TextBlock x:Name="txtIntarzieri" Text="—" FontSize="22" FontWeight="Bold" Foreground="{StaticResource BorrowedOrange}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatCardStyle}" Background="{DynamicResource CardBackground}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Margin="10">
                        <Border Width="45" Height="45" Background="{StaticResource TotalBlueBg}" CornerRadius="12" Margin="0,0,15,0">
                            <fa5:ImageAwesome Icon="Solid_Envelope" Foreground="{StaticResource TotalBlue}" Width="20"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Notificări trimise" Foreground="{StaticResource TextMuted}" FontSize="13"/>
                            <TextBlock x:Name="txtNotifTrimise" Text="—" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TotalBlue}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatCardStyle}" Background="{DynamicResource CardBackground}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Margin="10">
                        <Border Width="45" Height="45" Background="{StaticResource BorrowedOrangeBg}" CornerRadius="12" Margin="0,0,15,0">
                            <fa5:ImageAwesome Icon="Solid_HourglassHalf" Foreground="{StaticResource BorrowedOrange}" Width="20"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="În așteptare" Foreground="{StaticResource TextMuted}" FontSize="13"/>
                            <TextBlock x:Name="txtInAsteptare" Text="—" FontSize="22" FontWeight="Bold" Foreground="{StaticResource BorrowedOrange}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatCardStyle}" Background="{DynamicResource CardBackground}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Margin="10">
                        <Border Width="45" Height="45" Background="{StaticResource StockGreenBg}" CornerRadius="12" Margin="0,0,15,0">
                            <fa5:ImageAwesome Icon="Solid_CheckCircle" Foreground="{StaticResource StockGreen}" Width="20"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Rezolvate" Foreground="{StaticResource TextMuted}" FontSize="13"/>
                            <TextBlock x:Name="txtRezolvate" Text="—" FontSize="22" FontWeight="Bold" Foreground="{StaticResource StockGreen}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <Border Grid.Row="2" Background="{DynamicResource CardBackground}"  CornerRadius="15"
                    Effect="{StaticResource CardShadow}" Padding="16" Margin="10,0,10,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{DynamicResource InputBackground}" CornerRadius="10"
                            BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1" Height="40" Margin="0,0,12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <fa5:ImageAwesome Icon="Solid_Search" Foreground="{DynamicResource TextMuted}" Width="14"
                                             VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <TextBox x:Name="txtSearch" Grid.Column="1" VerticalContentAlignment="Center"
                                     BorderThickness="0" Background="Transparent"
                                     Padding="4,0" FontSize="13" Foreground="{DynamicResource TextDark}"
                                     TextChanged="TxtSearch_TextChanged"/>
                        </Grid>
                    </Border>

                    <ComboBox x:Name="cbxClasa" Grid.Column="1" Width="150" Height="40" Margin="0,0,12,0"
                              FontSize="13" Background="Transparent" BorderBrush="#E2E8F0"
                              SelectionChanged="CbxClasa_SelectionChanged"/>

                    <ComboBox x:Name="cbxStatus" Grid.Column="2" Width="200" Height="40" Margin="0,0,12,0"
                              FontSize="13" Background="Transparent" BorderBrush="#E2E8F0"
                              SelectionChanged="CbxStatus_SelectionChanged">
                        <ComboBoxItem Content="Toate statusurile" IsSelected="True"/>
                        <ComboBoxItem Content="Întârziere &gt; 5 zile"/>
                        <ComboBoxItem Content="Întârziere 1-4 zile"/>
                    </ComboBox>

                    <Button Grid.Column="3" Style="{StaticResource ActionButtonStyle}"
                            Height="40" Click="BtnReset_Click"
                            Background="Transparent" Foreground="#475569">
                        <StackPanel Orientation="Horizontal">
                            <fa5:ImageAwesome Icon="Solid_Times" Width="11" Foreground="{DynamicResource TextPrimary}"
                                             Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Reset" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="3" Margin="10,0,10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{DynamicResource CardBackground}" CornerRadius="15"
        BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1"
        Effect="{StaticResource CardShadow}" ClipToBounds="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header Checkbox -->
                        <Border Grid.Row="0" Background="Transparent"
                BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="0,0,0,1" Padding="16,10">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox x:Name="chkSelectAll" VerticalAlignment="Center"
                          Margin="0,0,10,0" Checked="ChkSelectAll_Changed"
                          Unchecked="ChkSelectAll_Changed"/>
                                <TextBlock x:Name="txtSelectAll" Text="Selectează toate (0)"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Column Headers -->
                        <Border Grid.Row="1" Background="{DynamicResource InputBackground}"
                BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="0,0,0,1" Padding="16,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"/>
                                <TextBlock Grid.Column="1" Text="ELEV" Style="{StaticResource ColHeaderStyle}" Foreground="{DynamicResource TextMuted}"/>
                                <TextBlock Grid.Column="2" Text="CARTE" Style="{StaticResource ColHeaderStyle}" Foreground="{DynamicResource TextMuted}"/>
                                <TextBlock Grid.Column="3" Text="TERMEN" Style="{StaticResource ColHeaderStyle}" Foreground="{DynamicResource TextMuted}"/>
                                <TextBlock Grid.Column="4" Text="ZILE ÎNT." Style="{StaticResource ColHeaderStyle}" Foreground="{DynamicResource TextMuted}"/>
                                <TextBlock Grid.Column="5" Text="EMAIL" Style="{StaticResource ColHeaderStyle}" Foreground="{DynamicResource TextMuted}"/>
                                <TextBlock Grid.Column="6" Text="STATUS" Style="{StaticResource ColHeaderStyle}" Foreground="{DynamicResource TextMuted}"/>
                            </Grid>
                        </Border>

                        <!-- Scrollable Content -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="spRanduri">
                                <Border x:Name="bdPlaceholder" Padding="40" Visibility="Collapsed">
                                    <StackPanel HorizontalAlignment="Center">
                                        <fa5:ImageAwesome Icon="Solid_CheckCircle" Width="48"
                                         Foreground="{DynamicResource StockGreen}" HorizontalAlignment="Center"
                                         Margin="0,0,0,16"/>
                                        <TextBlock Text="Nu există întârzieri active!"
                                                FontSize="16" FontWeight="SemiBold"
                                                Foreground="{DynamicResource TextPrimary}"
                                                HorizontalAlignment="Center"/>
                                        <TextBlock Text="Toți elevii au returnat cărțile la timp."
                                                FontSize="13" Foreground="{DynamicResource TextMuted}"
                                                HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Footer -->
                        <Border Grid.Row="3" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="0,1,0,0" Padding="16,10">
                            <Grid>
                                <TextBlock x:Name="txtPaginareInfo"
                           Text="Pagina 1 din 1 · 0 înregistrări"
                           Foreground="{DynamicResource TextGray}" FontSize="12"
                           VerticalAlignment="Center"/>
                                <StackPanel x:Name="spPaginator" Orientation="Horizontal"
                            HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
                <Grid Grid.Column="1" Margin="16,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">

                        <Button x:Name="btnTrimite"
                                Style="{StaticResource ActionPanelButtonStyle}"
                                Background="#6210CC" Foreground="White"
                                Height="45" Margin="0,0,0,8"
                                Click="BtnTrimite_Click">
                            <StackPanel Orientation="Horizontal">
                                <fa5:ImageAwesome Icon="Solid_Envelope" Foreground="White" Width="14"
                                                 Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtBtnTrimite" Text="Trimite notificări (0)"
                                           FontWeight="SemiBold" FontSize="13"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnAnuleaza"
                                Style="{StaticResource ActionPanelButtonStyle}"
                                Background="#FEE2E2" Foreground="#DC2626"
                                Click="BtnAnuleaza_Click">
                            <StackPanel Orientation="Horizontal">
                                <fa5:ImageAwesome Icon="Solid_Times" Foreground="#DC2626" Width="12"
                                                 Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Anulează selecția" FontWeight="SemiBold" FontSize="13"/>
                            </StackPanel>
                        </Button>

                        <Border BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Margin="0,8,0,12"/>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Background="{DynamicResource CardBackground}" CornerRadius="15"
                            Effect="{StaticResource CardShadow}"
                            Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                <fa5:ImageAwesome Icon="Solid_History" Width="13" Foreground="#6210CC"
                                                 Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Notificări recente" FontWeight="Bold" FontSize="14"
                                           Foreground="{DynamicResource TextPrimary}"/>
                            </StackPanel>

                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel x:Name="spIstoricNotificari">

                                    <Border x:Name="bdIstoricPlaceholder" Padding="10,20" Visibility="Collapsed">
                                        <StackPanel HorizontalAlignment="Center">
                                            <fa5:ImageAwesome Icon="Regular_Bell" Width="28"
                                                             Foreground="#CBD5E1"
                                                             HorizontalAlignment="Center"
                                                             Margin="0,0,0,10"/>
                                            <TextBlock Text="Nicio notificare trimisă încă."
                                                       FontSize="12" Foreground="{StaticResource TextGray}"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <Border x:Name="overlayLoading" Background="#88FFFFFF" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <fa5:ImageAwesome Icon="Solid_Spinner" Width="40" Foreground="#6210CC"
                                 HorizontalAlignment="Center"
                                 RenderTransformOrigin="0.5,0.5">
                    <fa5:ImageAwesome.RenderTransform>
                        <RotateTransform x:Name="spinnerRotate"/>
                    </fa5:ImageAwesome.RenderTransform>
                </fa5:ImageAwesome>
                <TextBlock x:Name="txtLoading" Text="Se trimite..." FontSize="15"
                           FontWeight="SemiBold" Foreground="#6210CC" Margin="0,12,0,0"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
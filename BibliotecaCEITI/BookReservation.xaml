<UserControl x:Class="BibliotecaCEITI.BookReservation"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BibliotecaCEITI"
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             mc:Ignorable="d" d:DesignWidth="1100"
             Background="{StaticResource BackgroundGray}" Height="Auto">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <StackPanel>
                <TextBlock Text="Rezervare carte" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextDark}" Margin="0,0,0,15"/>
            </StackPanel>

            <Border Style="{StaticResource StatCardStyle}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="1. Caută și selectează cartea" FontWeight="Bold" FontSize="18" Foreground="{StaticResource TextDark}" Margin="0,0,0,15"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="SearchBookBox" 
                                 Style="{StaticResource ModernInputStyle}"
                                 Tag="Caută după titlu, autor, ISBN..." 
                                 VerticalContentAlignment="Center"
                                 Padding="10,0" Height="43" />

                        <Button Grid.Column="1" Style="{StaticResource GlobalActionButtonStyle}" Width="130" Margin="15,0,0,4">
                            <StackPanel Orientation="Horizontal">
                                <fa5:ImageAwesome Icon="Solid_Search" Foreground="White" Width="14" Margin="0,0,8,0"/>
                                <TextBlock Text="Caută"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <DataGrid x:Name="BooksDataGrid" Style="{StaticResource ModernDataGridStyle}" 
                              Height="200" AutoGenerateColumns="False" IsReadOnly="True"/>
                </StackPanel>
            </Border>

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="141*"/>
                    <ColumnDefinition Width="71*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource StatCardStyle}" Margin="10,10,10,10">
                    <StackPanel>
                        <TextBlock Text="2. Selectează elevul pentru rezervare" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>
                        <TextBox x:Name="SearchStudentBox" 
                                 Style="{StaticResource ModernInputStyle}"
                                 Tag="Caută elev după nume..."
                                 Margin="0,0,0,10" Height="40"/>

                        <DataGrid x:Name="StudentsDataGrid" Style="{StaticResource ModernDataGridStyle}" 
                                  Height="358" AutoGenerateColumns="False" IsReadOnly="True"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource StatCardStyle}" Margin="10,10,10,10">
                    <StackPanel VerticalAlignment="Center" Margin="20,0,28,0" >
                        <TextBlock Text="3. Confirmare" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>
                        <Border Height="280" CornerRadius="20" Background="#ebebeb" Margin="0,0,0,15">
                            <Image x:Name="imgCoperta" Stretch="Uniform"/>
                        </Border>
                        <Grid Margin="0,5">
                            <TextBlock Text="Elev:" Foreground="{StaticResource TextGray}"/>
                            <TextBlock x:Name="TxtFinalStudent" Text="-" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                        </Grid>
                        <Grid Margin="0,5">
                            <TextBlock Text="Carte:" Foreground="{StaticResource TextGray}"/>
                            <TextBlock x:Name="TxtSelectedBook" Text="Neselectat" HorizontalAlignment="Right" FontWeight="SemiBold" MaxWidth="150" TextTrimming="CharacterEllipsis"/>
                        </Grid>

                        <Button Style="{StaticResource GlobalActionButtonStyle}" Margin="0,20,0,0" Height="45" Padding="5,10,5,10" Width="242">
                            <StackPanel Orientation="Horizontal">
                                <fa5:ImageAwesome Icon="Solid_Check" Foreground="White" Width="14" Margin="0,0,8,0"/>
                                <TextBlock Text="Salvează Rezervarea" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource StatCardStyle}" Background="#FFFFFF" Height="476">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="109*"/>
                        <ColumnDefinition Width="141*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <TextBlock Text="Deținută în prezent de:" FontWeight="Bold" FontSize="15" Margin="0,0,0,10" Foreground="{StaticResource TextDark}"/>
                        <DataGrid x:Name="CurrentLoanGrid" Style="{StaticResource ModernDataGridStyle}" Height="309" IsReadOnly="True"/>

                        <Border Background="#FFF5F5" CornerRadius="8" Padding="12" Margin="0,15,0,0" BorderBrush="#FEB2B2" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <fa5:ImageAwesome Icon="Solid_ExclamationCircle" Foreground="#C53030" Width="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Cand o carte se va returna, elevul va primi un mesaj." 
                                           Foreground="#9B2C2C" FontSize="15" TextWrapping="Wrap" Width="325"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Coada de așteptare (Alte rezervări active)" FontWeight="Bold" FontSize="15" Margin="0,0,0,10" Foreground="{StaticResource TextDark}"/>
                        <DataGrid x:Name="WaitListGrid" Style="{StaticResource ModernDataGridStyle}" 
                                  Height="401" AutoGenerateColumns="False" IsReadOnly="True"/>
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
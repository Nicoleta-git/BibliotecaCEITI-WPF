<UserControl x:Class="BibliotecaCEITI.BookReservation"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BibliotecaCEITI"
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             mc:Ignorable="d" d:DesignWidth="1100" d:Height="1400"
             Background="{StaticResource BackgroundGray}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Titlu -->
                <RowDefinition Height="Auto"/>
                <!-- Sectiunea 1: Carti -->
                <RowDefinition Height="Auto"/>
                <!-- Sectiunea 2 & 3: Elevi si Confirmare -->
                <RowDefinition Height="Auto"/>
                <!-- Sectiunea 4: Info Coada -->
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Rezervare carte" FontSize="28" FontWeight="Bold" 
                       Foreground="{StaticResource TextDark}" Margin="0,0,0,25"/>

            <Border Grid.Row="1" Style="{StaticResource StatCardStyle}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="1. Caută și selectează cartea" FontWeight="Bold" FontSize="18" 
                               Foreground="{StaticResource TextDark}" Margin="0,0,0,15"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="SearchBookBox" 
                                 Style="{StaticResource ModernInputStyle}"
                                 Tag="Caută după titlu, autor, ISBN..." 
                                 VerticalContentAlignment="Center"
                                 Padding="10,0" Height="43" />

                        <Button x:Name="BtnSearchBook" Grid.Column="1" Style="{StaticResource GlobalActionButtonStyle}" 
                                MinWidth="130" Margin="15,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <fa5:ImageAwesome Icon="Solid_Search" Foreground="White" Width="14" Margin="0,0,8,0"/>
                                <TextBlock Text="Caută"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <DataGrid x:Name="BooksDataGrid" Style="{StaticResource ModernDataGridStyle}" 
                              MinHeight="150" MaxHeight="300" AutoGenerateColumns="False" IsReadOnly="True" Height="312"/>
                </StackPanel>
            </Border>

            <Grid Grid.Row="2" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sectiunea Elev -->
                <Border Grid.Column="0" Style="{StaticResource StatCardStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="2. Selectează elevul pentru rezervare" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>
                        <TextBox x:Name="SearchStudentBox" 
                                 Style="{StaticResource ModernInputStyle}"
                                 Tag="Caută elev după nume..."
                                 Margin="0,0,0,10" Height="40"/>

                        <DataGrid x:Name="StudentsDataGrid" Style="{StaticResource ModernDataGridStyle}" 
                                  MinHeight="200" MaxHeight="400" AutoGenerateColumns="False" IsReadOnly="True" Height="300"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource StatCardStyle}" Margin="10,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <!-- Titlu -->
                            <RowDefinition Height="*"/>
                            <!-- Imagine -->
                            <RowDefinition Height="Auto"/>
                            <!-- Detalii Text -->
                            <RowDefinition Height="Auto"/>
                            <!-- Buton -->
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="3. Confirmare" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

                        <Border Grid.Row="1" Height="200" CornerRadius="10" Background="#F4F7FE" Margin="0,0,0,15">
                            <Image x:Name="imgCoperta" Stretch="Uniform" Margin="5"/>
                        </Border>

                        <StackPanel Grid.Row="2" Margin="0,0,0,15">
                            <Grid Margin="0,5">
                                <TextBlock Text="Elev:" Foreground="{StaticResource TextGray}"/>
                                <TextBlock x:Name="TxtFinalStudent" Text="-" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                            </Grid>
                            <Grid Margin="0,5">
                                <TextBlock Text="Carte:" Foreground="{StaticResource TextGray}"/>
                                <TextBlock x:Name="TxtSelectedBook" Text="Neselectat" HorizontalAlignment="Right" 
                                           FontWeight="SemiBold" MaxWidth="150" TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </StackPanel>

                        <Button x:Name="BtnSaveReservation" Grid.Row="3"
                                Style="{StaticResource GlobalActionButtonStyle}" 
                                Height="45" Cursor="Hand"
                                Click="BtnSaveReservation_Click">
                            <StackPanel Orientation="Horizontal">
                                <fa5:ImageAwesome Icon="Solid_Check" Foreground="White" Width="14" Margin="0,0,8,0"/>
                                <TextBlock Text="Salvează Rezervarea" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="3" Style="{StaticResource StatCardStyle}" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,20,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Deținută în prezent de:" FontWeight="Bold" FontSize="15" 
                                   Margin="0,0,0,10" Foreground="{StaticResource TextDark}"/>

                        <DataGrid Grid.Row="1" x:Name="CurrentLoanGrid" Style="{StaticResource ModernDataGridStyle}" 
                                  MinHeight="150" MaxHeight="250" IsReadOnly="True"/>

                        <Border Grid.Row="2" Background="#FFF5F5" CornerRadius="8" Padding="12" Margin="0,15,0,0" 
                                BorderBrush="#FEB2B2" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <fa5:ImageAwesome Icon="Solid_ExclamationCircle" Foreground="#C53030" Width="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Când o carte se va returna, elevul va primi un mesaj." 
                                           Foreground="#9B2C2C" FontSize="13" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Coada de așteptare" FontWeight="Bold" FontSize="15" 
                                   Margin="0,0,0,10" Foreground="{StaticResource TextDark}"/>
                        <DataGrid x:Name="WaitListGrid" Style="{StaticResource ModernDataGridStyle}" 
                                  MinHeight="150" MaxHeight="320" AutoGenerateColumns="False" IsReadOnly="True" Height="308"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
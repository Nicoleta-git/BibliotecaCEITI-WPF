<UserControl x:Class="BibliotecaCEITI.Dashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:BibliotecaCEITI"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">

    <UserControl.Resources>
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.2" Color="{DynamicResource ShadowColor}"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource WindowBackground}">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="8,0,8,20">
                <StackPanel>
                    <TextBlock Text="Bun venit, Admin!" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="Dashboard - Sistem Gestiune Biblioteca CEITI" Foreground="{DynamicResource TextMuted}" FontSize="14" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>

            <UniformGrid Grid.Row="1" Columns="4">

                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="46" Height="46" Background="{DynamicResource TotalBlueBg}" CornerRadius="12" Margin="0,0,16,0">
                            <fa5:ImageAwesome Icon="Solid_Book" Foreground="{DynamicResource TotalBlue}" Width="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Cărți totale" Foreground="{DynamicResource TextMuted}" FontSize="13" FontWeight="Medium"/>
                            <TextBlock x:Name="total_carti" Text="1,248" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="46" Height="46" Background="{DynamicResource StockGreenBg}" CornerRadius="12" Margin="0,0,16,0">
                            <fa5:ImageAwesome Icon="Solid_CheckCircle" Foreground="{DynamicResource StockGreen}" Width="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Disponibile" Foreground="{DynamicResource TextMuted}" FontSize="13" FontWeight="Medium"/>
                            <TextBlock x:Name="numar_disponibile" Text="842" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="46" Height="46" Background="{DynamicResource BorrowedOrangeBg}" CornerRadius="12" Margin="0,0,16,0">
                            <fa5:ImageAwesome Icon="Solid_Clock" Foreground="{DynamicResource BorrowedOrange}" Width="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Împrumutate" Foreground="{DynamicResource TextMuted}" FontSize="13" FontWeight="Medium"/>
                            <TextBlock x:Name="imprumuturi" Text="312" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="46" Height="46" Background="{DynamicResource ReservedPurpleBg}" CornerRadius="12" Margin="0,0,16,0">
                            <fa5:ImageAwesome Icon="Solid_Bookmark" Foreground="{DynamicResource ReservedPurple}" Width="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Rezervate" Foreground="{DynamicResource TextMuted}" FontSize="13" FontWeight="Medium"/>
                            <TextBlock x:Name="rezervari" Text="94" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Grid.Row="2" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.7*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource StatCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="Activitate Împrumuturi" FontWeight="Bold" FontSize="18" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="(Ultimele luni)" Foreground="{DynamicResource TextMuted}" FontSize="12" VerticalAlignment="Bottom" Margin="8,0,0,2"/>
                        </StackPanel>

                        <lvc:CartesianChart Grid.Row="1" 
                                            Background="Transparent"
                                            Series="{Binding Series}"
                                            XAxes="{Binding XAxes}"
                                            YAxes="{Binding YAxes}"/>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Top Cărți" FontWeight="Bold" FontSize="18" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,16"/>

                        <Grid Margin="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="coperta_1" Width="44" Height="58" Background="{DynamicResource WindowBackground}" CornerRadius="6"/>
                            <StackPanel Grid.Column="1" Margin="14,0" VerticalAlignment="Center">
                                <TextBlock x:Name="titlu_1" Text="Amintiri din copilărie" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock x:Name="autor_1" Text="Ion Creangă" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                            </StackPanel>
                            <TextBlock x:Name="imprumuturi_1" Grid.Column="2" Text="128" VerticalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource TextSecondary}"/>
                        </Grid>

                        <Separator Background="{DynamicResource WindowBackground}" Margin="0,4"/>

                        <Grid Margin="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="coperta_2" Width="44" Height="58" Background="{DynamicResource WindowBackground}" CornerRadius="6"/>
                            <StackPanel Grid.Column="1" Margin="14,0" VerticalAlignment="Center">
                                <TextBlock x:Name="titlu_2" Text="Enigma Otiliei" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock x:Name="autor_2" Text="G. Călinescu" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                            </StackPanel>
                            <TextBlock x:Name="imprumuturi_2" Grid.Column="2" Text="97" VerticalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource TextSecondary}"/>
                        </Grid>

                        <Separator Background="{DynamicResource WindowBackground}" Margin="0,4"/>

                        <Grid Margin="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="coperta_3" Width="44" Height="58" Background="{DynamicResource WindowBackground}" CornerRadius="6"/>
                            <StackPanel Grid.Column="1" Margin="14,0" VerticalAlignment="Center">
                                <TextBlock x:Name="titlu_3" Text="Moromeții" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock x:Name="autor_3" Text="Marin Preda" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                            </StackPanel>
                            <TextBlock x:Name="imprumuturi_3" Grid.Column="2" Text="86" VerticalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource TextSecondary}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
<UserControl x:Class="BibliotecaCEITI.CheckInBorrow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             xmlns:local="clr-namespace:BibliotecaCEITI"
             mc:Ignorable="d" 
             Background="#F4F7FE" FontFamily="Segoe UI"
             d:DesignHeight="850" d:DesignWidth="1200">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <StackPanel Margin="30,20,30,20" HorizontalAlignment="Left">
                <Button x:Name="btnBack" Background="Transparent" BorderThickness="0" 
                        Padding="0" Cursor="Hand" Margin="0,0,0,10" HorizontalAlignment="Left" Click="btnBack_Click">
                    <StackPanel Orientation="Horizontal">
                        <fa5:ImageAwesome Icon="Solid_ArrowLeft" Width="12" Foreground="#2563EB" Margin="0,0,8,0"/>
                        <TextBlock Text="Înapoi la listă" FontSize="14" Foreground="#2563EB" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <TextBlock Text="Procesare Împrumut" FontSize="28" FontWeight="Bold" Foreground="#1E293B"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,20,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" VerticalAlignment="Top">
                    <ContentControl x:Name="ActiveBorrowContent" Height="608" />
                </Border>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0" Width="257">
                    <Button Content="Anuleaza" Width="93" Margin="0,0,10,0" Style="{StaticResource GlobalActionButtonStyle}" Background="#e66250" Click="Button_Click"/>
                    <Button x:Name="btnNext" Style="{StaticResource GlobalActionButtonStyle}" Background="#1DA154" Width="154" Click="btnNext_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Continuă" Foreground="White" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <fa5:ImageAwesome Icon="Solid_ChevronRight" Width="10" Foreground="White" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <Border Grid.Column="1" Background="White" CornerRadius="15" BorderBrush="#E2E8F0" BorderThickness="1">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="Împrumuturi active ale elevului" 
                                   FontWeight="Bold" Foreground="#1E293B" 
                                   VerticalAlignment="Center" FontSize="14"/>
                        <Button HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Cursor="Hand">
                            <fa5:ImageAwesome Icon="Solid_Sync" Width="14" Foreground="#94A3B8"/>
                        </Button>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border x:Name="EmptyStateBorder" Background="#F8FAFC" CornerRadius="10" BorderBrush="#F1F5F9" BorderThickness="1" Visibility="Collapsed">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                                    <fa5:ImageAwesome Icon="Regular_FileAlt" Width="30" Foreground="#CBD5E1" Margin="0,0,0,15"/>
                                    <TextBlock Text="Elevul nu are împrumuturi active." 
                                               TextWrapping="Wrap" TextAlignment="Center"
                                               Foreground="#94A3B8" FontSize="13"/>
                                </StackPanel>
                            </Border>

                            <DataGrid x:Name="BooksGrid"
                                      RowHeight="120"
                                      Style="{StaticResource ModernDataGridStyle}"
                                      AutoGenerateColumns="False"
                                      ColumnWidth="*"
                                      EnableRowVirtualization="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                      CanUserAddRows="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#E2E8F0"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      RowBackground="White"
                                      Height="600">

                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Width="100" CanUserResize="False">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10,5,10,5">
                                                    <Border Width="70" Height="95" Background="#F7FAFC" CornerRadius="8" BorderBrush="#EDF2F7" BorderThickness="1" Margin="0,0,0,0">
                                                        <Image x:Name="imgCoperta" Source="{Binding Coperta_carte}" Stretch="Uniform"/>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="Detalii Carte" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel VerticalAlignment="Center" Margin="10,0,10,0">
                                                    <TextBlock Text="{Binding Carte}" FontWeight="SemiBold" Foreground="#2B6CB0" FontSize="14" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding Autor}" Foreground="#718096" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
<UserControl x:Class="BibliotecaCEITI.ManualBorrow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             mc:Ignorable="d" 
             Background="#F4F7FE"
             FontFamily="Segoe UI" d:DesignWidth="1000" d:Height="853">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="DefaultControls.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="LeftAlignedCellStyle" TargetType="DataGridCell">
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="0,0,0,10">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
            <StackPanel Margin="40,30">

                <Button x:Name="btnBack" Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Click="BtnInapoi_Click" HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <fa5:ImageAwesome Icon="Solid_ArrowLeft" Width="10" Margin="0,0,8,0" Foreground="#4483EC"/>
                        <TextBlock Text="Înapoi la împrumuturi" Foreground="#4483EC" FontSize="15"
                                   FontWeight="Medium" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <TextBlock Text="Manuale" FontSize="28" FontWeight="Bold" Foreground="#1E293B" Margin="0,10,0,5"/>
                <TextBlock Text="Selectează un manual sau o grupă pentru a gestiona împrumuturile."
                           Foreground="#718096" FontSize="13" Margin="0,0,0,25"/>

                <Border Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1"
                        Padding="10" Margin="0,0,0,15" HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button x:Name="BtnModImprumut" Content="Împrumut" Width="160" Height="36" Margin="10,0,20,0"
                                Tag="activ"
                                Style="{StaticResource GlobalActionButtonStyle}" Click="BtnModImprumut_Click"/>
                        <Button x:Name="BtnModReturnare" Content="Returnare" Width="160" Height="36"
                                Background="#E2E8F0" Foreground="#64748B"
                                Style="{StaticResource GlobalActionButtonStyle}" Click="BtnModReturnare_Click"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1"
                        Padding="20" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <TextBlock Text="Categoria" FontSize="12" Foreground="#64748B" Margin="0,0,0,6"/>
                            <ComboBox x:Name="CmbCategorie" Height="40" HorizontalAlignment="Stretch"
                                      DisplayMemberPath="NumeCategorie" SelectionChanged="CmbCategorie_SelectionChanged"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,20,0">
                            <TextBlock Text="Manual" FontSize="12" Foreground="#64748B" Margin="0,0,0,6"/>
                            <ComboBox x:Name="CmbManual" Height="40" HorizontalAlignment="Stretch"
                                      DisplayMemberPath="Denumire" SelectedValuePath="Id" SelectionChanged="CmbManual_SelectionChanged"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,20,0">
                            <TextBlock x:Name="TxtNumarExemplare" Text="Exemplare existente: 0" FontSize="12" Foreground="#64748B" Margin="0,0,0,6"/>
                            <Button x:Name="BtnAdaugaExemplare" Content="+ Adaugă exemplare" Width="180" Height="40"
                                    Style="{StaticResource GlobalActionButtonStyle}" Click="BtnAdaugaExemplare_Click"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3">
                            <TextBlock Text="Grupa" FontSize="12" Foreground="#64748B" Margin="0,0,0,6"/>
                            <ComboBox x:Name="CmbGrupa" Height="40" HorizontalAlignment="Stretch"
                                      DisplayMemberPath="NumeGrupa" SelectionChanged="CmbGrupa_SelectionChanged"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1"
                        Padding="20" Margin="0,0,0,15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="TxtGrupLabel" Grid.Row="0" Text="Elevi în grupa A" FontSize="15" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,12"/>

                        <DataGrid x:Name="DgElevi" Grid.Row="1"
                                  Style="{StaticResource ModernDataGridStyle}"
                                  AutoGenerateColumns="False" 
                                  CanUserAddRows="False" 
                                  Foreground="Black" 
                                  MinHeight="360" 
                                  Margin="0,10,0,0"
                                  HorizontalAlignment="Stretch"
                                  VirtualizingPanel.IsVirtualizing="False"
                                  ScrollViewer.CanContentScroll="False"
                                  EnableRowVirtualization="False">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Elev" Width="*" IsReadOnly="True" CellStyle="{StaticResource LeftAlignedCellStyle}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                                                <Grid Margin="0,0,10,0">
                                                    <Ellipse Width="32" Height="32" Fill="#F0F2F5"/>
                                                    <TextBlock Text="{Binding Initiale}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Foreground="#2D3748" FontSize="13"/>
                                                </Grid>
                                                <TextBlock Text="{Binding NumeElev}" VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Foreground="#2D3748"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Selectat" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox x:Name="chkManual" IsChecked="{Binding AreManual, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                      Checked="areManual_Checked" Unchecked="areManual_Checked"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1"
                        Padding="20,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="TxtEleviSelectati" Grid.Column="0" Width="300" Height="38" IsReadOnly="True"
                                 VerticalAlignment="Center" Text="Elevi selectati:"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <CheckBox x:Name="ChkBifeazaToti" Content="Bifează toți"
                                      VerticalAlignment="Center" Margin="0,0,20,0"
                                      FontSize="14" Foreground="#2D3748"
                                      Checked="ChkBifeazaToti_Changed" Unchecked="ChkBifeazaToti_Changed"/>

                            <Button x:Name="BtnSalveaza" Content="Salvează împrumut" Width="180" Height="40"
                                    Style="{StaticResource GlobalActionButtonStyle}" Click="BtnSalveaza_Click"/>

                            <Button x:Name="BtnReturnare" Content="Confirmă returnare" Width="180" Height="40"
                                    Visibility="Collapsed"
                                    Style="{StaticResource GlobalActionButtonStyle}" Click="BtnReturnare_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
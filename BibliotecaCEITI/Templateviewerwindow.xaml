<Window x:Class="BibliotecaCEITI.TemplateViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa5="http://schemas.fontawesome.com/icons/"
        Title="TemplateViewerWindow"
        Width="1020" Height="700"
        MinWidth="700" MinHeight="450"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        Background="Transparent"
        Opacity="0">

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- ANIMAȚIE DESCHIDERE — declanșată la Loaded                 -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard Timeline.DesiredFrameRate="60">

                    <DoubleAnimation
                    Storyboard.TargetProperty="Opacity"
                    From="0" To="1"
                    Duration="0:0:0.300">
                        <DoubleAnimation.EasingFunction>
                            <QuarticEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                    <DoubleAnimation
                    Storyboard.TargetName="RootBorder"
                    Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                    From="24" To="0"
                    Duration="0:0:0.300">
                        <DoubleAnimation.EasingFunction>
                            <QuarticEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                    <DoubleAnimation
                    Storyboard.TargetName="RootBorder"
                    Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                    From="0.96" To="1"
                    Duration="0:0:0.300">
                        <DoubleAnimation.EasingFunction>
                            <QuarticEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                    <DoubleAnimation
                    Storyboard.TargetName="RootBorder"
                    Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                    From="0.96" To="1"
                    Duration="0:0:0.300">
                        <DoubleAnimation.EasingFunction>
                            <QuarticEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Window.Resources>

        <Style x:Key="LineNumberBox" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#1E3A5F"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="Padding" Value="0,10,10,10"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Hidden"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Hidden"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
        </Style>

        <Style x:Key="CodeEditBox" TargetType="TextBox">
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="AcceptsTab" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#8BAFD4"/>
            <Setter Property="CaretBrush" Value="#8BAFD4"/>
            <Setter Property="Padding" Value="16,10,16,10"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="SelectionBrush" Value="#152843"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
        </Style>

        <Style x:Key="TitleBarBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#3A5578"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#0F1E30"/>
                                <Setter Property="Foreground" Value="#8BAFD4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1C2A3F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FooterBtn" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

    </Window.Resources>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- ROOT BORDER — poartă TransformGroup pentru animații        -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Border x:Name="RootBorder"
            CornerRadius="10"
            Background="#0D1117"
            BorderBrush="#1C2A3F"
            BorderThickness="1"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
                <TranslateTransform Y="0"/>
            </TransformGroup>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="0" Opacity="0.7"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="38"/>
                <RowDefinition Height="56"/>
            </Grid.RowDefinitions>

            <!-- ══════════════════════════════════════════════ -->
            <!-- ROW 0: TITLE BAR                              -->
            <!-- ══════════════════════════════════════════════ -->
            <Border Grid.Row="0"
                    Background="#080E16"
                    CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="16,0,12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="12" Height="12" Fill="#FF5F57" Margin="0,0,6,0"/>
                        <Ellipse Width="12" Height="12" Fill="#FEBC2E" Margin="0,0,6,0"/>
                        <Ellipse Width="12" Height="12" Fill="#28C840" Margin="0,0,20,0"/>

                        <fa5:ImageAwesome Icon="Regular_FileCode" Width="14"
                                          Foreground="#2E6DB4"
                                          VerticalAlignment="Center"
                                          Margin="0,0,8,0"/>
                        <TextBlock x:Name="txtTitluFereastra"
                                   Text="template.html"
                                   Foreground="#8BAFD4"
                                   FontFamily="Consolas"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                        <Ellipse x:Name="dotUnsaved"
                                 Width="7" Height="7"
                                 Fill="#5E96D8"
                                 Margin="8,0,0,0"
                                 VerticalAlignment="Center"
                                 Visibility="Collapsed"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               x:Name="txtTitluCentru"
                               Text="Cod template: ..."
                               Foreground="#2B4063"
                               FontFamily="Consolas"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="btnMinimize"
                                Style="{StaticResource TitleBarBtn}"
                                Click="BtnMinimize_Click"
                                ToolTip="Minimizare">
                            <fa5:ImageAwesome Icon="Solid_WindowMinimize" Width="10" Foreground="#3A5578"/>
                        </Button>
                        <Button x:Name="btnMaximize"
                                Style="{StaticResource TitleBarBtn}"
                                Click="BtnMaximize_Click"
                                ToolTip="Maximizare/Restaurare">
                            <fa5:ImageAwesome Icon="Regular_WindowMaximize" Width="11" Foreground="#3A5578"/>
                        </Button>
                        <Button x:Name="btnClose"
                                Style="{StaticResource TitleBarBtn}"
                                Click="BtnClose_Click"
                                ToolTip="Închide">
                            <fa5:ImageAwesome Icon="Solid_Times" Width="11" Foreground="#3A5578"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════ -->
            <!-- ROW 1: TAB BAR                                -->
            <!-- ══════════════════════════════════════════════ -->
            <Border Grid.Row="1"
                    Background="#0A1520"
                    BorderBrush="#1C2A3F"
                    BorderThickness="0,1,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="#0D1117"
                            BorderBrush="#1C2A3F"
                            BorderThickness="1,0,1,0"
                            Padding="16,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <fa5:ImageAwesome Icon="Brands_Html5" Width="13"
                                              Foreground="#1F6FD8"
                                              VerticalAlignment="Center"
                                              Margin="0,0,7,0"/>
                            <TextBlock x:Name="txtTabName"
                                       Text="template.html"
                                       Foreground="#8BAFD4"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="0"
                            Height="2"
                            Background="#2E6DB4"
                            VerticalAlignment="Bottom"/>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,16,0">
                        <TextBlock Text="setari" Foreground="#1E3A5F" FontFamily="Consolas" FontSize="11"/>
                        <TextBlock Text=" › " Foreground="#13203A" FontFamily="Consolas" FontSize="11"/>
                        <TextBlock x:Name="txtBreadcrumb"
                                   Text="template"
                                   Foreground="#1E3A5F"
                                   FontFamily="Consolas"
                                   FontSize="11"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════ -->
            <!-- ROW 2: EDITOR                                 -->
            <!-- ══════════════════════════════════════════════ -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="56"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#0A1520">
                    <TextBox x:Name="lineNumberBox" Style="{StaticResource LineNumberBox}"/>
                </Border>

                <Rectangle Grid.Column="1" Fill="#13203A"/>

                <TextBox x:Name="codeBox"
                         Grid.Column="2"
                         Style="{StaticResource CodeEditBox}"
                         TextChanged="CodeBox_TextChanged"
                         ScrollViewer.ScrollChanged="CodeBox_ScrollChanged"/>
            </Grid>

            <!-- ══════════════════════════════════════════════ -->
            <!-- ROW 3: STATUS BAR                             -->
            <!-- ══════════════════════════════════════════════ -->
            <Border Grid.Row="3"
                    Background="#080E16"
                    BorderBrush="#13203A"
                    BorderThickness="0,1,0,0">
                <Grid Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#0F1E30" CornerRadius="3" Padding="6,2" Margin="0,0,10,0">
                            <TextBlock Text="HTML" Foreground="#1F6FD8" FontFamily="Consolas" FontSize="11"/>
                        </Border>
                        <TextBlock Text="UTF-8" Foreground="#1E3A5F" FontFamily="Consolas" FontSize="11" Margin="0,0,12,0"/>
                        <TextBlock Text="•" Foreground="#13203A" FontFamily="Consolas" FontSize="11" Margin="0,0,12,0"/>
                        <TextBlock Text="Consolas 13px" Foreground="#1E3A5F" FontFamily="Consolas" FontSize="11"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="txtLinie" Text="Ln 1, Col 1"
                                   Foreground="#1E3A5F" FontFamily="Consolas" FontSize="11" Margin="0,0,12,0"/>
                        <TextBlock x:Name="txtTotalLinii" Text="0 linii"
                                   Foreground="#1E3A5F" FontFamily="Consolas" FontSize="11"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════ -->
            <!-- ROW 4: FOOTER                                 -->
            <!-- ══════════════════════════════════════════════ -->
            <Border Grid.Row="4"
                    Background="#080E16"
                    BorderBrush="#13203A"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,10,10">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <fa5:ImageAwesome Icon="Solid_InfoCircle" Width="12"
                                          Foreground="#1E3A5F" Margin="0,0,7,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Modificările se salvează direct în baza de date."
                                   Foreground="#1E3A5F" FontFamily="Segoe UI" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">

                        <Button x:Name="btnAnuleaza"
                                Style="{StaticResource FooterBtn}"
                                Width="110"
                                Margin="0,0,10,0"
                                Background="#0F1E30"
                                Foreground="#8BAFD4"
                                Click="BtnAnuleaza_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                            <StackPanel Orientation="Horizontal">
                                <fa5:ImageAwesome Icon="Solid_Times" Width="11"
                                                  Foreground="#3A5578" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Anulează" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnSalveaza"
                                Style="{StaticResource FooterBtn}"
                                Width="170"
                                Background="#1A4F9C"
                                Foreground="#C8DFEF"
                                FontWeight="SemiBold"
                                Click="BtnSalveaza_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="#4A9EDB"
                                         Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Salvează template" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>

<UserControl x:Class="BibliotecaCEITI.BookAi"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Storyboard x:Key="BubbleIntroAnimation">
                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25"/>
                <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.3">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="{DynamicResource CardBackground}" CornerRadius="20" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                <TextBlock Text="✦" Foreground="{DynamicResource PrimaryBlue}" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Gemini" FontWeight="Bold" FontSize="20" Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="Pune întrebări" FontSize="13" Foreground="{DynamicResource TextMuted}"/>
                </StackPanel>
            </StackPanel>

            <Border Grid.Row="1" Background="{DynamicResource ControlBackground}" CornerRadius="15" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1" Padding="10" Margin="0,0,0,15">
                <ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ChatItemsControl" Margin="0,5">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,6,0,6" HorizontalAlignment="{Binding Alignment}">
                                    <Grid.RenderTransform>
                                        <TranslateTransform Y="0"/>
                                    </Grid.RenderTransform>

                                    <Border Background="{Binding BackgroundBrush}" 
                                            CornerRadius="{Binding BubbleRadius}" 
                                            Padding="14,10" 
                                            MaxWidth="340"
                                            BorderThickness="{Binding BorderThickness}"
                                            BorderBrush="{Binding BorderBrush}">
                                        <TextBlock Text="{Binding MessageText}" 
                                                   TextWrapping="Wrap" 
                                                   FontSize="14" 
                                                   Foreground="{Binding TextBrush}"/>
                                    </Border>

                                    <Grid.Triggers>
                                        <EventTrigger RoutedEvent="Grid.Loaded">
                                            <BeginStoryboard Storyboard="{StaticResource BubbleIntroAnimation}"/>
                                        </EventTrigger>
                                    </Grid.Triggers>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Background="{DynamicResource InputBackground}" CornerRadius="12" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1" Padding="5">
                    <TextBox x:Name="input" 
                             BorderThickness="0" 
                             Background="Transparent"
                             Height="45" 
                             VerticalContentAlignment="Center" 
                             Padding="12,0" 
                             FontSize="14"
                             Foreground="{DynamicResource TextPrimary}"
                             GotFocus="Input_GotFocus"
                             Text="Scrie întrebarea ta..."/>
                </Border>

                <Button Grid.Column="1" 
                        Click="OnSendClick"
                        Margin="12,0,0,0" 
                        Width="48" Height="48" 
                        Background="{DynamicResource PrimaryBlue}" 
                        BorderThickness="0" 
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="btnBorder" Background="{TemplateBinding Background}" CornerRadius="12">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="btnBorder" Property="Background" Value="{DynamicResource PrimaryBlueHover}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="➤" Foreground="White" FontSize="18"/>
                </Button>
            </Grid>
        </Grid>
    </Border>
</UserControl>
<UserControl x:Class="BibliotecaCEITI.BookAi"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Border Background="White" CornerRadius="25" BorderBrush="#E2E8F0" BorderThickness="1">
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="✦" Foreground="#3B82F6" FontSize="26" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Gemini" FontWeight="Bold" FontSize="22" Foreground="#1E293B"/>
                    <TextBlock Text="Pune întrebări" FontSize="14" Foreground="#64748B"/>
                </StackPanel>
            </StackPanel>

            <Border Grid.Row="1" Background="White" CornerRadius="20" Padding="15" Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="25" Direction="270" ShadowDepth="2" Opacity="0.07"/>
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBox x:Name="response" 
                             TextWrapping="Wrap" 
                             BorderThickness="0" 
                             Background="Transparent" 
                             IsReadOnly="True"
                             FontSize="15" 
                             Foreground="#334155" 
                             Text="Rezultatul va apărea aici..." 
                             MinHeight="360"/>
                </ScrollViewer>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Background="#F8FAFC" CornerRadius="15" BorderBrush="#E2E8F0" BorderThickness="1.5" Padding="5">
                    <TextBox x:Name="input" 
                             BorderThickness="0" 
                             Background="Transparent"
                             Height="50" 
                             VerticalContentAlignment="Center" 
                             Padding="15,0" 
                             FontSize="15"
                             Foreground="#1E293B"
                             GotFocus="Input_GotFocus"
                             Text="Scrie întrebarea ta..."/>
                </Border>

                <Button Grid.Column="1" 
                        Click="OnSendClick"
                        Margin="15,0,0,0" 
                        Width="55" Height="55" 
                        Background="#3B82F6" 
                        BorderThickness="0" 
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="➤" Foreground="White" FontSize="22"/>
                </Button>
            </Grid>
        </Grid>
    </Border>
</UserControl>
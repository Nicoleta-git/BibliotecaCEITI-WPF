<UserControl x:Class="BibliotecaCEITI.CheckInBorrowStep_3"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             xmlns:local="clr-namespace:BibliotecaCEITI"
             mc:Ignorable="d" Background="Transparent"
             d:DesignHeight="550" d:DesignWidth="800">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="InfoBarStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource BorrowedOrangeBg}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorrowedOrange}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="Padding" Value="15,12"/>
            </Style>

            <Style TargetType="DatePicker">
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushLight}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Padding" Value="10,0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DatePicker">
                            <Border x:Name="DatePickerRoot"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <Grid x:Name="InternalGrid">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <DatePickerTextBox x:Name="PART_TextBox"
                                                       Grid.Column="0"
                                                       HorizontalContentAlignment="Stretch"
                                                       VerticalContentAlignment="Center"
                                                       Focusable="False"
                                                       Background="Transparent"
                                                       BorderThickness="0"
                                                       Padding="{TemplateBinding Padding}"
                                                       Foreground="{TemplateBinding Foreground}"/>

                                    <Button x:Name="PART_Button"
                                            Grid.Column="1"
                                            Width="40"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Focusable="False">
                                        <fa5:ImageAwesome Icon="Solid_CalendarAlt" 
                                                         Width="16" 
                                                         Foreground="{DynamicResource TotalBlue}"/>
                                    </Button>

                                    <Popup x:Name="PART_Popup"
                                           Placement="Bottom"
                                           AllowsTransparency="True"
                                           StaysOpen="False"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="{DynamicResource TotalBlue}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1" CornerRadius="12" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,25">
                <TextBlock Text="3. Detalii carte" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
            </StackPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Column: Dates and Duration Form -->
                <!-- Left Column: Dates and Duration Form -->
                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Data împrumut" Margin="0,0,0,8" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextMuted}"/>
                        <DatePicker x:Name="data_imprumut" 
                    Height="45" 
                    VerticalContentAlignment="Center"
                    SelectedDateChanged="cbDurataImprumut_SelectionChanged"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Durata împrumut" Margin="0,0,0,8" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextMuted}"/>
                        <ComboBox x:Name="cbDurataImprumut" 
                  Height="45" 
                  VerticalContentAlignment="Center" 
                  SelectionChanged="cbDurataImprumut_SelectionChanged">
                            <ComboBoxItem Content="14 zile" IsSelected="True"/>
                            <ComboBoxItem Content="21 zile"/>
                            <ComboBoxItem Content="30 zile"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Cartea selectată" Margin="0,0,0,8" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextMuted}"/>
                    <Border Background="{DynamicResource WindowBackground}" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1" CornerRadius="12" Margin="0" Padding="20">
                        <StackPanel>
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border x:Name="imgCoperta" Grid.Column="0" Width="70" Height="100" Background="{DynamicResource InputBackground}" CornerRadius="6" Margin="0,0,15,0"/>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="titlu_carte" Text="Amintiri din copilărie" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="autor_carte" Text="Ion Creangă" FontSize="14" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Margin="0,0,0,15">
                                <Grid Margin="0,4">
                                    <TextBlock Text="ISBN:" Foreground="{DynamicResource TextMuted}" FontWeight="Medium"/>
                                    <TextBlock x:Name="isbn_carte" Text="978-973-31-0070-6" HorizontalAlignment="Right" Foreground="{DynamicResource TextSecondary}"/>
                                </Grid>
                                <Grid Margin="0,4">
                                    <TextBlock Text="Categorie:" Foreground="{DynamicResource TextMuted}" FontWeight="Medium"/>
                                    <TextBlock x:Name="denumire_categorie" Text="Literatură română" HorizontalAlignment="Right" Foreground="{DynamicResource TextSecondary}"/>
                                </Grid>
                                <Grid Margin="0,4">
                                    <TextBlock Text="Cod:" Foreground="{DynamicResource TextMuted}" FontWeight="Medium"/>
                                    <TextBlock x:Name="cod_inventar" Text="C12345" HorizontalAlignment="Right" Foreground="{DynamicResource TextSecondary}"/>
                                </Grid>
                            </StackPanel>

                            <Border x:Name="fon_disponibilitate" HorizontalAlignment="Left" Background="{DynamicResource StockGreenBg}" CornerRadius="6" Padding="12,6">
                                <TextBlock x:Name="disponibilitate_exemplar" Text="Disponibilă" Foreground="{DynamicResource StockGreen}" FontWeight="Bold" FontSize="12"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <Border x:Name="atentionare" Grid.Row="2" Style="{StaticResource InfoBarStyle}" Margin="0,20,0,0">
                <StackPanel Orientation="Horizontal">
                    <fa5:ImageAwesome Icon="Solid_InfoCircle" Width="16" Foreground="{DynamicResource BorrowedOrange}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="atentionare_elev" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}" FontSize="13">
                        <Run Text="Elevul este responsabil pentru carte până la data de "/>
                        <Run Text="04.06.2025." FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
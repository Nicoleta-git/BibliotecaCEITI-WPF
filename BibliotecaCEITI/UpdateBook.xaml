<UserControl x:Class="BibliotecaCEITI.UpdateBook"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             mc:Ignorable="d"
             Background="#F4F7FE" 
             FontFamily="Segoe UI"
             d:DesignHeight="860" d:DesignWidth="1100">

    <UserControl.Resources>
        <ResourceDictionary>
            <!-- Importing global styles for textboxes, buttons, and combos -->
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="DefaultControls.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Specific brushes for the "Active" status badge -->
            <SolidColorBrush x:Key="SuccessGreen" Color="#DCFCE7"/>
            <SolidColorBrush x:Key="SuccessText" Color="#166534"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header Section -->
            <RowDefinition Height="*"/>
            <!-- Main Content Section -->
        </Grid.RowDefinitions>

        <!-- TOP NAVIGATION & ACTIONS HEADER -->
        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderLight}" BorderThickness="0,0,0,1" Padding="40,20" Panel.ZIndex="1">
            <Grid>
                <!-- Title and Return link -->
                <StackPanel HorizontalAlignment="Left">
                    <TextBlock Text="Detalii carte" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>

                    <Button x:Name="btnBack" 
                            Background="Transparent" 
                            BorderThickness="0" 
                            Cursor="Hand" 
                            Margin="0,5,0,0" 
                            Click="BtnBack_Click">
                        <StackPanel Orientation="Horizontal">
                            <fa5:ImageAwesome Icon="Solid_ArrowLeft" Width="12" Margin="0,0,8,0" Foreground="RoyalBlue"/>
                            <TextBlock Text="Înapoi la listă" Foreground="RoyalBlue" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Primary Action Buttons (Cancel / Save) -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Width="110" Height="36" Background="White" BorderBrush="{StaticResource BorderLight}" Margin="0,0,10,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                        <StackPanel Orientation="Horizontal">
                            <fa5:ImageAwesome Icon="Solid_Times" Width="12" Margin="0,0,8,0"/>
                            <TextBlock Text="Anulează"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnSalveazaModificari" Width="190" Style="{StaticResource PrimaryButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <fa5:ImageAwesome Icon="Solid_Save" Width="14" Foreground="White" Margin="0,0,10,0"/>
                            <TextBlock Text="Salvează modificările"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="40,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/>
                    <!-- Left Column: Book Cover -->
                    <ColumnDefinition Width="*"/>
                    <!-- Right Column: Forms & Details -->
                </Grid.ColumnDefinitions>

                <!-- BOOK COVER MANAGEMENT -->
                <StackPanel Grid.Column="0" Margin="0,0,25,0">
                    <Border CornerRadius="8" Background="White" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" Padding="20">
                        <StackPanel>
                            <!-- Image Preview Container -->
                            <Border Height="380" CornerRadius="4" Background="#F1F5F9" Margin="0,0,0,15">
                                <Image x:Name="imgCoperta" Stretch="UniformToFill"/>
                            </Border>
                            <!-- Cover Actions -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Background="White" BorderBrush="{StaticResource BorderLight}" Height="36" Margin="0,0,5,0">
                                    <StackPanel Orientation="Horizontal">
                                        <fa5:ImageAwesome Icon="Solid_Upload" Width="12" Margin="0,0,8,0" Foreground="{StaticResource TextDark}"/>
                                        <TextBlock Text="Schimbă coperta"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="1" Width="36" Height="36" Background="White" BorderBrush="#FECACA" Foreground="#DC2626">
                                    <fa5:ImageAwesome Icon="Solid_Trash" Width="14" Foreground="#DC2626"/>
                                </Button>
                            </Grid>
                            <!-- Cover URL Link -->
                            <TextBox x:Name="txtCopertaUrl" Margin="0,12,0,0" FontSize="11" Tag="URL Copertă"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- MAIN DATA FORM -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- General Info -->
                        <RowDefinition Height="Auto"/>
                        <!-- Technical Info & System Sidebar -->
                    </Grid.RowDefinitions>

                    <!-- TOP FORM: Basic Information -->
                    <Border Grid.Row="0" Background="White" CornerRadius="8" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" Padding="20" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Titlu carte *" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtTitlu" Margin="0,0,0,15"/>

                            <TextBlock Text="Autor *" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="cbAutor" Margin="0,0,0,15"/>

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Gen / Categorie *" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox x:Name="cbCategorie"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Ediție" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="txtEditie"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Descriere" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtDescriere" Height="100" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="10"/>
                        </StackPanel>
                    </Border>

                    <!-- BOTTOM FORM: Technical Details & System Info Sidebar -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="300"/>
                        </Grid.ColumnDefinitions>

                        <!-- LEFT SIDE: ISBN, Publisher, Pricing -->
                        <Border Grid.Column="0" Background="White" CornerRadius="8" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" Padding="20" Margin="0,0,20,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Margin="0,0,10,15">
                                    <TextBlock Text="ISBN" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="txtIsbn"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="10,0,0,15">
                                    <TextBlock Text="Editura" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox x:Name="cbEditura"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Margin="0,0,10,15">
                                    <TextBlock Text="An apariție" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="txtAnPublicare"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,15">
                                    <TextBlock Text="Limba" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox x:Name="cbLimba"/>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Margin="0,0,10,0">
                                    <TextBlock Text="Preț Vânzare (MDL)" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="txtPretMdl"/>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Preț Chirie" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="txtPretChirie"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- RIGHT SIDE: System Info Sidebar -->
                        <Border Grid.Column="1" Background="White" CornerRadius="8" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" Padding="20">
                            <StackPanel>
                                <TextBlock Text="Informații sistem" FontWeight="Bold" FontSize="14" Margin="0,0,0,15" Foreground="{StaticResource TextDark}"/>
                                <Grid Margin="0,0,0,10">
                                    <TextBlock Text="ID Carte:" Foreground="{StaticResource LabelGray}"/>
                                    <TextBlock x:Name="lblIdCarte" Text="C12345" HorizontalAlignment="Right" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                                </Grid>
                                <!-- Status Badge -->
                                <Border Background="{StaticResource SuccessGreen}" Padding="10,5" CornerRadius="4" HorizontalAlignment="Right" Margin="0,10,0,20">
                                    <TextBlock Text="Activă" Foreground="{StaticResource SuccessText}" FontWeight="SemiBold" FontSize="12"/>
                                </Border>
                                <Separator Margin="0,0,0,15" Background="{StaticResource BorderLight}"/>
                                <!-- Audit Info -->
                                <TextBlock Text="Ultima modificare de:" FontSize="11" Foreground="{StaticResource LabelGray}"/>
                                <TextBlock x:Name="lblBibliotecar" Text="Admin (ID: 1)" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextDark}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
<Window x:Class="BibliotecaCEITI.UpdateBook"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Modificare Detalii Carte" Height="820" Width="1100"
        Background="#F9FAFB" WindowStartupLocation="CenterScreen" FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Color Palette matching the UI reference -->
        <SolidColorBrush x:Key="HeaderDark" Color="#020617"/>
        <SolidColorBrush x:Key="PrimaryBlue" Color="#2563EB"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#DCFCE7"/>
        <SolidColorBrush x:Key="SuccessText" Color="#166534"/>
        <SolidColorBrush x:Key="BorderGray" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="LabelText" Color="#475569"/>

        <!-- Reusable Styles -->
        <Style x:Key="InputLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource LabelText}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderGray}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderGray}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <!-- Black Header -->
            <RowDefinition Height="Auto"/>
            <!-- Breadcrumbs/Actions -->
            <RowDefinition Height="*"/>
            <!-- Main Content -->
        </Grid.RowDefinitions>

        <!-- 1. Top Black Navbar (Matching Screenshot) -->

        <!-- 2. Sub-Header (Actions) -->
        <Border Background="White" BorderBrush="{StaticResource BorderGray}" BorderThickness="0,0,0,1" Padding="40,15" Margin="0,0,0,712" Grid.RowSpan="3">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Detalii carte" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>
                    <Button Content="← Înapoi la listă" Background="Transparent" BorderThickness="0" Foreground="{StaticResource PrimaryBlue}" Cursor="Hand" HorizontalAlignment="Left" Margin="0,5,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="Anulează" Width="100" Height="36" Background="White" BorderBrush="{StaticResource BorderGray}" Margin="0,0,10,0"/>
                    <Button x:Name="btnSalveazaModificari" Content="Salvează modificările" Width="160" Height="36" Background="{StaticResource PrimaryBlue}" Foreground="White" FontWeight="SemiBold">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 3. Main Form Area -->
        <Grid Grid.Row="2" Margin="40,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <!-- Left: Cover & Basic -->
                <ColumnDefinition Width="*"/>
                <!-- Right: Technical Details -->
            </Grid.ColumnDefinitions>

            <!-- LEFT COLUMN: Visuals & Main Info -->
            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                <Border CornerRadius="8" Background="White" BorderBrush="{StaticResource BorderGray}" BorderThickness="1" Padding="20">
                    <StackPanel>
                        <!-- Cover Image Preview -->
                        <Border Height="380" CornerRadius="4" Background="#F1F5F9" Margin="0,0,0,15">
                            <Image x:Name="imgCoperta" Stretch="UniformToFill"/>
                        </Border>

                        <!-- Cover Actions -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Content="↑ Schimbă coperta" Background="White" BorderBrush="{StaticResource BorderGray}" Height="36" Margin="0,0,5,0"/>
                            <Button Grid.Column="1" Content="🗑" Width="36" Height="36" Background="White" BorderBrush="#FECACA" Foreground="#DC2626"/>
                        </Grid>
                        <TextBox x:Name="txtCopertaUrl" Margin="0,10,0,0" FontSize="10" Style="{StaticResource ModernTextBox}" Tag="URL Copertă (p_coperta_url)"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- RIGHT COLUMN: Detailed Form Fields -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top Section: Title, Author, Description -->
                <Border Grid.Row="0" Background="White" CornerRadius="8" BorderBrush="{StaticResource BorderGray}" BorderThickness="1" Padding="20" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Titlu carte *" Style="{StaticResource InputLabel}"/>
                        <TextBox x:Name="txtTitlu" Style="{StaticResource ModernTextBox}" Margin="0,0,0,15"/>

                        <TextBlock Text="Autor *" Style="{StaticResource InputLabel}"/>
                        <ComboBox x:Name="cbAutor" Style="{StaticResource ModernComboBox}" Margin="0,0,0,15"/>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Gen / Categorie *" Style="{StaticResource InputLabel}"/>
                                <ComboBox x:Name="cbCategorie" Style="{StaticResource ModernComboBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="Ediție (p_editie)" Style="{StaticResource InputLabel}"/>
                                <TextBox x:Name="txtEditie" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Descriere (p_descriere)" Style="{StaticResource InputLabel}"/>
                        <TextBox x:Name="txtDescriere" Height="120" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="10"/>
                    </StackPanel>
                </Border>

                <!-- Bottom Section: Technical & Inventory -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="280"/>
                    </Grid.ColumnDefinitions>

                    <!-- Technical Details -->
                    <Border Grid.Column="0" Background="White" CornerRadius="8" BorderBrush="{StaticResource BorderGray}" BorderThickness="1" Padding="20" Margin="0,0,20,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Margin="0,0,10,15">
                                <TextBlock Text="ISBN" Style="{StaticResource InputLabel}"/>
                                <TextBox x:Name="txtIsbn" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="10,0,0,15">
                                <TextBlock Text="Editura" Style="{StaticResource InputLabel}"/>
                                <ComboBox x:Name="cbEditura" Style="{StaticResource ModernComboBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Margin="0,0,10,15">
                                <TextBlock Text="An apariție" Style="{StaticResource InputLabel}"/>
                                <TextBox x:Name="txtAnPublicare" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,15">
                                <TextBlock Text="Limba" Style="{StaticResource InputLabel}"/>
                                <ComboBox x:Name="cbLimba" Style="{StaticResource ModernComboBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Margin="0,0,10,0">
                                <TextBlock Text="Preț Vânzare (MDL)" Style="{StaticResource InputLabel}"/>
                                <TextBox x:Name="txtPretMdl" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="Preț Chirie (Manual)" Style="{StaticResource InputLabel}"/>
                                <TextBox x:Name="txtPretChirie" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Status & Inventory Sidebar -->
                    <Border Grid.Column="1" Background="White" CornerRadius="8" BorderBrush="{StaticResource BorderGray}" BorderThickness="1" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Informații sistem" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>

                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="ID Carte:" Foreground="{StaticResource LabelText}"/>
                                <TextBlock x:Name="lblIdCarte" Text="C12345" HorizontalAlignment="Right" FontWeight="Bold"/>
                            </Grid>

                            <Border Background="{StaticResource SuccessGreen}" Padding="10,5" CornerRadius="4" HorizontalAlignment="Right" Margin="0,10,0,20">
                                <TextBlock Text="Activă" Foreground="{StaticResource SuccessText}" FontWeight="SemiBold" FontSize="12"/>
                            </Border>

                            <Separator Margin="0,0,0,15"/>

                            <Button Content="📋 Istoric modificări" Height="38" Background="#EFF6FF" Foreground="{StaticResource PrimaryBlue}" BorderThickness="0" Margin="0,0,0,10"/>
                            <TextBlock Text="Ultima modificare de:" FontSize="11" Foreground="{StaticResource LabelText}"/>
                            <TextBlock x:Name="lblBibliotecar" Text="Admin (ID: 1)" FontSize="11" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
<UserControl x:Class="BibliotecaCEITI.CheckInBorrowStep_1"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             xmlns:local="clr-namespace:BibliotecaCEITI"
             mc:Ignorable="d" Background="Transparent"
             d:DesignHeight="608" d:DesignWidth="800">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="SearchButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource TotalBlue}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Padding" Value="25,10"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1" CornerRadius="12">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="25">

                <TextBlock Text="1. Caută elev" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,25"/>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1" CornerRadius="8" Margin="0,0,15,0" Padding="12,5" Background="{DynamicResource InputBackground}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <fa5:ImageAwesome Icon="Solid_Search" Width="14" Foreground="{DynamicResource TextMuted}" Margin="0,0,10,0"/>
                            <TextBox x:Name="SearchBox" Grid.Column="1" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" 
                                     Foreground="{DynamicResource TextPrimary}" FontSize="14" TextChanged="SearchBox_TextChanged" GotFocus="SearchBox_GotFocus" LostFocus="SearchBox_LostFocus"/>
                        </Grid>
                    </Border>
                    <Button Grid.Column="1" Content="Caută" Style="{StaticResource SearchButtonStyle}" Background="{DynamicResource PrimaryEmerald}" Width="120" Height="45"/>
                </Grid>

                <TextBlock Text="Rezultate căutare" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,10"/>
                <DataGrid x:Name="StudentsGrid"
                          Style="{StaticResource ModernDataGridStyle}"
                          AutoGenerateColumns="False"
                          ColumnWidth="*"
                          EnableColumnVirtualization="True"
                          EnableRowVirtualization="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{DynamicResource BorderBrushLight}"
                          BorderThickness="0"
                          Background="Transparent"
                          RowBackground="{DynamicResource DataGridRowBackground}"
                          Height="180" SelectionChanged="StudentsGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="70" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Ellipse Width="32" Height="32" Fill="{DynamicResource InputBackground}"/>
                                        <TextBlock Text="{Binding Initiale}" 
                                                   VerticalAlignment="Center" 
                                                   HorizontalAlignment="Center" 
                                                   FontWeight="Bold" 
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="13"/>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Elev" Binding="{Binding NumeElev}" 
                                            FontWeight="Bold" Foreground="{DynamicResource PrimaryEmerald}"/>
                        <DataGridTextColumn Header="Telefon" Binding="{Binding Telefon}" Width="1.2*"/>
                        <DataGridTextColumn Header="Grupa" Binding="{Binding Grupa}" Width="*"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="1.5*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock Text="Elev selectat" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,20,0,10"/>
                <Border Background="{DynamicResource WindowBackground}" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1" CornerRadius="12" Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="60" Height="60" Background="{DynamicResource PrimaryEmerald}" CornerRadius="30" Margin="0,0,20,0">
                            <TextBlock x:Name="initiale_elev" Text="N/A" Foreground="White" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock x:Name="nume_elev" Text="Selecteaza elev" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,10,0"/>
                                <Border x:Name="fon_activ" Background="{DynamicResource StockGreenBg}" CornerRadius="4" Padding="8,2">
                                    <TextBlock x:Name="activ_elev" Text="Elev activ" Foreground="{DynamicResource StockGreen}" FontSize="11" FontWeight="SemiBold" Height="16"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="grupa_elev" Text="Grupa: ..." Foreground="{DynamicResource TextMuted}" FontSize="13"/>
                                <TextBlock Text=" • " Foreground="{DynamicResource BorderBrushDark}"/>
                                <TextBlock x:Name="ID_elev" Text="ID Elev: ..." Foreground="{DynamicResource TextMuted}" FontSize="13"/>
                                <TextBlock Text=" • " Foreground="{DynamicResource BorderBrushDark}"/>
                                <TextBlock x:Name="telefon_elev" Text="Telefon: ..." Foreground="{DynamicResource TextMuted}" FontSize="13"/>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="2" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Top"/>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
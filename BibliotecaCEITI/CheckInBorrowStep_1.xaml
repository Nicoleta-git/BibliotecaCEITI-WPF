<UserControl x:Class="BibliotecaCEITI.CheckInBorrowStep_1"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             xmlns:local="clr-namespace:BibliotecaCEITI"
             mc:Ignorable="d" Background="Transparent"
             d:DesignHeight="520" d:DesignWidth="800">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="SearchButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="#2563EB"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Padding" Value="25,10"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="White" BorderBrush="Transparent" BorderThickness="1" Height="520" VerticalAlignment="Center">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,0,0,38">
            <StackPanel Margin="25">

                <!-- HEADER TITLE -->
                <TextBlock Text="1. Caută elev" FontSize="20" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,25"/>

                <!-- SEARCH BAR SECTION -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Margin="0,0,15,0" Padding="12,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <fa5:ImageAwesome Icon="Solid_Search" Width="14" Foreground="#94A3B8" Margin="0,0,10,0"/>
                            <TextBox x:Name="SearchBox" Grid.Column="1" BorderThickness="0" VerticalContentAlignment="Center" 
                                     Foreground="#1E293B" FontSize="14" TextChanged="SearchBox_TextChanged"/>
                        </Grid>
                    </Border>
                    <Button Grid.Column="1" Content="Caută" Style="{StaticResource SearchButtonStyle}" Width="120" Height="45"/>
                </Grid>

                <!-- DATAGRID: search user -->
                <TextBlock Text="Rezultate căutare" FontSize="14" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,10"/>
                <DataGrid x:Name="StudentsGrid"
                          Style="{StaticResource ModernDataGridStyle}"
                          AutoGenerateColumns="False"
                          ColumnWidth="*"
                          EnableColumnVirtualization="True"
                          EnableRowVirtualization="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          CanUserAddRows="False"
                          Height="157" SelectionChanged="StudentsGrid_SelectionChanged">

                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="70" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Ellipse Width="32" Height="32" Fill="#F0F2F5"/>
                                        <TextBlock Text="{Binding Initiale}" 
                                   VerticalAlignment="Center" 
                                   HorizontalAlignment="Center" 
                                   FontWeight="Bold" 
                                   Foreground="#2D3748"
                                   FontSize="13"/>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Elev" Binding="{Binding NumeElev}" 
                            FontWeight="Bold" Foreground="#2B6CB0"/>
                        <DataGridTextColumn Header="Telefon" Binding="{Binding Telefon}" Width="1.2*"/>
                        <DataGridTextColumn Header="Grupa" Binding="{Binding Grupa}" Width="*"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="1.5*"/>
                    </DataGrid.Columns>
                </DataGrid>



                <!-- SELECTED STUDENT PREVIEW (Updates based on selection) -->
                <TextBlock Text="Elev selectat" FontSize="14" FontWeight="SemiBold" Foreground="#64748B" Margin="0,10,0,10"/>
                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="60" Height="60" Background="#2563EB" CornerRadius="30" Margin="0,0,20,0">
                            <TextBlock x:Name="initiale_elev" Text="TN" Foreground="White" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock x:Name="nume_elev" Text="Titei Nicoleta" FontSize="18" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,10,0"/>
                                <Border x:Name="fon_activ" Background="#F0FDF4" CornerRadius="4" Padding="8,2">
                                    <TextBlock x:Name="activ_elev" Text="Elev activ" Foreground="#16A34A" FontSize="11" FontWeight="SemiBold" Height="16"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="grupa_elev" Text="Clasa: XII" Foreground="#64748B" FontSize="13"/>
                                <TextBlock Text=" • " Foreground="#CBD5E1"/>
                                <TextBlock x:Name="ID_elev" Text="ID Elev: 2023007" Foreground="#64748B" FontSize="13"/>
                                <TextBlock Text=" • " Foreground="#CBD5E1"/>
                                <TextBlock x:Name="telefon_elev" Text="Telefon: 0722 123 456" Foreground="#64748B" FontSize="13"/>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="2" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Top"/>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="WindowBackground" Color="#F4F7FE"/>
    <SolidColorBrush x:Key="CardBackground" Color="White"/>
    <SolidColorBrush x:Key="ControlBackground" Color="White"/>
    <SolidColorBrush x:Key="InputBackground" Color="#F5F6F7"/>
    <SolidColorBrush x:Key="HeaderWhite" Color="#FFFFFF"/>

    <SolidColorBrush x:Key="BorderBrushLight" Color="#E2E8F0"/>
    <SolidColorBrush x:Key="BorderBrushDark" Color="#CBD5E1"/>

    <SolidColorBrush x:Key="TextPrimary" Color="#1E293B"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#2D3748"/>
    <SolidColorBrush x:Key="TextMuted" Color="#718096"/>
    <SolidColorBrush x:Key="TextGray" Color="#8A92A6"/>
    <SolidColorBrush x:Key="LabelGray" Color="#64748B"/>

    <SolidColorBrush x:Key="PrimaryBlue" Color="#2563EB"/>
    <SolidColorBrush x:Key="PrimaryBlueHover" Color="#1D4ED8"/>
    <SolidColorBrush x:Key="PrimaryBlueSelected" Color="#DBEAFE"/>
    <SolidColorBrush x:Key="TextBlueSelected" Color="#1E40AF"/>

    <SolidColorBrush x:Key="PrimaryPurple" Color="#6210CC"/>
    <SolidColorBrush x:Key="LoginPurple" Color="#6a11cb"/>
    <SolidColorBrush x:Key="HoverBlue" Color="#2575fc"/>

    <SolidColorBrush x:Key="TotalBlue" Color="#2563EB"/>
    <SolidColorBrush x:Key="TotalBlueBg" Color="#EFF6FF"/>
    <SolidColorBrush x:Key="StockGreen" Color="#2F855A"/>
    <SolidColorBrush x:Key="StockGreenBg" Color="#F0FFF4"/>
    <SolidColorBrush x:Key="BorrowedOrange" Color="#C05621"/>
    <SolidColorBrush x:Key="BorrowedOrangeBg" Color="#FFFAF0"/>
    <SolidColorBrush x:Key="ReservedPurple" Color="#6210CC"/>
    <SolidColorBrush x:Key="ReservedPurpleBg" Color="#F5F3FF"/>
    <Color x:Key="ShadowColor">#A3AED0</Color>

    <Style x:Key="SidebarBorderStyle" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#6210CC" Offset="0"/>
                    <GradientStop Color="#2E70FF" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
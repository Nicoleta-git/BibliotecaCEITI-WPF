<Window x:Class="BibliotecaCEITI.Loading"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Loading" Height="450" Width="800"
        WindowStartupLocation="CenterScreen" 
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        UseLayoutRounding="True">

    <Window.Resources>
        <Style x:Key="RoundedProgressBar" TargetType="ProgressBar">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="Root" Height="{TemplateBinding Height}">
                            <Border Name="PART_Track" CornerRadius="12" Background="#E2E8F0" />
                            <Decorator x:Name="PART_Indicator" HorizontalAlignment="Left">
                                <Border Name="Indicator" CornerRadius="12">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                            <GradientStop Color="#2563EB" Offset="0.0" />
                                            <GradientStop Color="#60A5FA" Offset="1.0" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border CornerRadius="12" Opacity="0.3">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="Transparent" Offset="0"/>
                                                <GradientStop Color="White" Offset="0.5"/>
                                                <GradientStop Color="Transparent" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                </Border>
                            </Decorator>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="0,40,0,40" ClipToBounds="True" BorderBrush="#CBD5E1" BorderThickness="3">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFFFFF" Offset="0.0" />
                <GradientStop Color="#F8FAFC" Offset="1.0" />
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" Direction="270" Opacity="0.2" ShadowDepth="8"/>
        </Border.Effect>

        <Grid>
            <!-- Decorative Background Elements -> Elipse -->
            <Ellipse Fill="#DBEAFE" Width="600" Height="600" Margin="-250,-300,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Opacity="0.6"/>
            <Ellipse Fill="#EFF6FF" Width="400" Height="400" Margin="0,0,-150,-150" HorizontalAlignment="Right" VerticalAlignment="Bottom" Opacity="0.8"/>
            <Ellipse Fill="#BFDBFE" Width="100" Height="100" Margin="0,40,120,0" HorizontalAlignment="Right" VerticalAlignment="Top" Opacity="0.3"/>

            <Grid Margin="50">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="1.2*" />
                </Grid.ColumnDefinitions>

                <!-- Left Column: Progress -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <Image Source="/Assets/Loading/BibliotecaCEITI-logo.png" 
                           Height="135" 
                           Stretch="Uniform" 
                           Margin="0,0,0,15"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           SnapsToDevicePixels="True"/>

                    <ProgressBar Name="MyProgressBar" 
                                 Style="{StaticResource RoundedProgressBar}" 
                                 Height="18" 
                                 Minimum="0" 
                                 Maximum="100" 
                                 Value="0"
                                 Margin="20,0" />

                    <TextBlock Name="StatusLabel" 
                               Text="Sistemul se pregătește..." 
                               HorizontalAlignment="Center" 
                               Margin="0,15,0,0" 
                               FontSize="15" 
                               FontFamily="Segoe UI Semibold"
                               Foreground="#1E40AF"
                               Opacity="0.9"/>
                </StackPanel>

                <!-- Right Column: Illustration -->
                <Grid Grid.Column="1">
                    <Image Source="/Assets/Loading/pc-loading.png" 
                           Stretch="Uniform" 
                           Margin="10,20,10,0"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           SnapsToDevicePixels="True"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
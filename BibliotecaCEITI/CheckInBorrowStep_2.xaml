<UserControl x:Class="BibliotecaCEITI.CheckInBorrowStep_2"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             xmlns:local="clr-namespace:BibliotecaCEITI"
             mc:Ignorable="d" Background="Transparent"
             d:DesignHeight="550" d:DesignWidth="800">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="SearchButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource TotalBlue}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Padding" Value="25,10"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1" CornerRadius="12">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="25">

                <TextBlock Text="2. Caută și selectează carte" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,25"/>

                <Grid Margin="0,0,0,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Căutare după autor" FontSize="13" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8" FontWeight="Medium"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="{DynamicResource InputBackground}" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1" CornerRadius="8" Margin="0,0,15,0" Padding="12,5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <fa5:ImageAwesome Icon="Solid_Search" Width="14" Foreground="{DynamicResource TextMuted}" Margin="0,0,10,0"/>
                                    <TextBox x:Name="SearchBox" Grid.Column="1" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" Foreground="{DynamicResource TextPrimary}" FontSize="14" HorizontalAlignment="Stretch" TextChanged="SearchBox_TextChanged" GotFocus="SearchBox_GotFocus" LostFocus="SearchBox_LostFocus" />
                                </Grid>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,15,0,0"/>
                </Grid>

                <TextBlock Text="Rezultate căutare" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,10"/>
                <DataGrid x:Name="BooksGrid"
                          Style="{StaticResource ModernDataGridStyle}"
                          AutoGenerateColumns="True"
                          ColumnWidth="*"
                          IsReadOnly="True"
                          CanUserAddRows="False" 
                          MaxHeight="250"
                          MinHeight="150" 
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{DynamicResource BorderBrushLight}"
                          BorderThickness="0"
                          Background="Transparent"
                          RowBackground="{DynamicResource DataGridRowBackground}"
                          AutoGeneratingColumn="BooksGrid_AutoGeneratingColumn" 
                          SelectionChanged="BooksGrid_SelectionChanged"/>

                <TextBlock Text="Carte selectată" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,20,0,10"/>
                <Border Background="{DynamicResource WindowBackground}" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock x:Name="titlu_carte_selectata" Text="{Binding SelectedItem.Titlu, ElementName=BooksGrid, FallbackValue='Titlu Carte'}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,10,0"/>
                                <Border x:Name="fon_disponibilitate" Background="{DynamicResource StockGreenBg}" CornerRadius="4" Padding="8,2">
                                    <TextBlock x:Name="disponibilitate_carte_selectata" Text="Disponibilă" Foreground="{DynamicResource StockGreen}" FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="autor_carte_selectata" Text="{Binding SelectedItem.Autor, ElementName=BooksGrid, FallbackValue='Autor: N/A', StringFormat='Autor: \{0\}'}" Foreground="{DynamicResource TextMuted}" FontSize="13"/>
                                <TextBlock Text=" • " Foreground="{DynamicResource BorderBrushDark}"/>
                                <TextBlock x:Name="cod_inventar_carte_selectata" Text="{Binding SelectedItem.Cod, ElementName=BooksGrid, FallbackValue='Cod: 0000', StringFormat='Cod: \{0\}'}" Foreground="{DynamicResource TextMuted}" FontSize="13"/>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="2" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Top"/>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
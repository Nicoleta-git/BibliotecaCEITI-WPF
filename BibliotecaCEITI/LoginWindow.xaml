<Window x:Class="BibliotecaCEITI.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BibliotecaCEITI"
        mc:Ignorable="d"
        Title="Login Biblioteca" Height="500" Width="850"
        WindowStyle="None" AllowsTransparency="True" 
        Background="Transparent" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Legatura catre silurile din Styles.xaml -->
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="30" Background="White">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" Direction="0" Opacity="0.2" ShadowDepth="0"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="30,0,0,30" ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{StaticResource LoginPurpleColor}" Offset="0"/>
                        <GradientStop Color="{StaticResource HoverBlueColor}" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <!-- Decor fundal -->
                    <Ellipse Width="200" Height="200" Fill="White" Opacity="0.1" Margin="-100,-100,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                        <TextBlock Text="Bun venit!" 
                                   Foreground="White" 
                                   FontSize="36" 
                                   FontWeight="ExtraBold"
                                   TextAlignment="Center"/>

                        <Separator Width="40" Height="4" 
                                   Background="White" 
                                   Margin="0,15"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Gestionează resursele bibliotecii CEITI cu ușurință." 
                                   Foreground="#E0E0E0" 
                                   FontSize="15" 
                                   TextWrapping="Wrap" 
                                   TextAlignment="Center" 
                                   Width="260"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="60,20,60,20">
                <Button Content="✕" 
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Top" 
                        Style="{StaticResource ControlButtonStyle}" 
                        Margin="0,0,-30,0" 
                        Click="ExitBtn"/>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Autentificare" 
                               Foreground="#333" 
                               FontSize="32" 
                               FontWeight="Bold"/>

                    <TextBlock Text="Introduceți datele de mai jos" 
                               Foreground="{StaticResource TextGray}" 
                               FontSize="14" 
                               Margin="0,5,0,35"/>

                    <TextBlock Text="Utilizator" 
                               Foreground="#666" 
                               Margin="0,0,0,8"/>
                    <TextBox Name="utlizatorTxt" 
                             Style="{StaticResource ModernInputStyle}" 
                             Margin="0,0,0,25"/>

                    <TextBlock Text="Parolă" 
                               Foreground="#666" 
                               Margin="0,0,0,8"/>
                    <PasswordBox Name="parolaTxt" 
                                 Style="{StaticResource ModernInputStyle}" 
                                 Margin="0,0,0,40"/>

                    <Button Name="conectareBtn" 
                            Content="CONECTARE" 
                            Height="45" 
                            Style="{StaticResource ModernButtonStyle}" 
                            Click="ConectareBtn_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>